-- ===== Fonctions de téléportation =====
local function StartInfiniteTeleport(player)
    if InfiniteTeleport.Active then StopInfiniteTeleport() end
    if not player or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
        warn("Joueur introuvable ou sans personnage")
        return
    end

    InfiniteTeleport.Active = true
    InfiniteTeleport.TargetPlayer = player

    local character = player.Character
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = false
        end
    end
    if character:FindFirstChild("Humanoid") then
        character.Humanoid.PlatformStand = true
        character.Humanoid.Sit = false
    end

    InfiniteTeleport.Connection = RunService.Heartbeat:Connect(function()
        if not InfiniteTeleport.Active or not InfiniteTeleport.TargetPlayer then
            StopInfiniteTeleport()
            return
        end
        local target = InfiniteTeleport.TargetPlayer
        if not target or not target.Character then
            StopInfiniteTeleport()
            return
        end
        local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
        local localHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if targetHRP and localHRP then
            local targetPos = targetHRP.Position
            local rootPart = LocalPlayer.Character.HumanoidRootPart
            local distance = InfiniteTeleport.Distance or 0
            local teleportPos = Vector3.new(targetPos.X, targetPos.Y - 3.5 + distance, targetPos.Z)
            rootPart.CFrame = CFrame.new(teleportPos)

            for _, part in ipairs(LocalPlayer.Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
            if LocalPlayer.Character:FindFirstChild("Humanoid") then
                LocalPlayer.Character.Humanoid.PlatformStand = true
                LocalPlayer.Character.Humanoid.Sit = false
                LocalPlayer.Character.Humanoid.Jump = false
            end
        end
    end)
    UpdateAllTeleportButtons()
end

local function StopInfiniteTeleport()
    if InfiniteTeleport.Connection then
        InfiniteTeleport.Connection:Disconnect()
        InfiniteTeleport.Connection = nil
    end
    if LocalPlayer.Character then
        if LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid.PlatformStand = false
            LocalPlayer.Character.Humanoid.Sit = false
        end
        for _, part in ipairs(LocalPlayer.Character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
    end
    InfiniteTeleport.Active = false
    InfiniteTeleport.TargetPlayer = nil
    UpdateAllTeleportButtons()
end

local function UpdateAllTeleportButtons()
    for _, child in ipairs(ScrollFrame:GetChildren()) do
        if child:IsA("Frame") and child.Name:match("PlayerItem_") then
            local btn = child:FindFirstChild("TeleportButton")
            if btn then
                local playerNameLabel = child:FindFirstChild("PlayerName")
                if playerNameLabel then
                    local displayName = playerNameLabel.Text:match("^(.-) %(") or playerNameLabel.Text
                    local target = nil
                    for _, p in ipairs(Players:GetPlayers()) do
                        if p.DisplayName == displayName or p.Name == displayName then
                            target = p
                            break
                        end
                    end
                    if target then
                        if InfiniteTeleport.Active and InfiniteTeleport.TargetPlayer == target then
                            btn.Text = "⏹ Arrêter"
                            btn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
                            btn.TextColor3 = Color3.fromRGB(255, 200, 200)
                        else
                            btn.Text = "🔗 Téléporter"
                            btn.BackgroundColor3 = Color3.fromRGB(40, 120, 200)
                            btn.TextColor3 = Color3.fromRGB(180, 220, 255)
                        end
                    end
                end
            end
        end
    end
end

