-- Fonction pour mettre à jour la liste des joueurs
local function UpdatePlayerList()
    for _, child in ipairs(ScrollFrame:GetChildren()) do
        if child:IsA("Frame") and child.Name:match("PlayerItem_") then
            child:Destroy()
        end
    end
    
    local playerList = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            table.insert(playerList, player)
        end
    end
    
    table.sort(playerList, function(a, b)
        return a.Name < b.Name
    end)
    
    for i, player in ipairs(playerList) do
        CreatePlayerItem(player, i)
    end
    
    ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, (#playerList * 53) + 10)
end

-- Appel initial
UpdatePlayerList()

-- Mettre à jour la liste quand des joueurs rejoignent/quittent
Players.PlayerAdded:Connect(function()
    UpdatePlayerList()
end)

Players.PlayerRemoving:Connect(function(player)
    if InfiniteTeleport.Active and InfiniteTeleport.TargetPlayer == player then
        StopInfiniteTeleport()
    end
    UpdatePlayerList()
end)

-- Fonction pour basculer le mode réduit
local function ToggleMinimize()
    IsMinimized = not IsMinimized
    
    if IsMinimized then
        FullSize.Width = MainFrame.Size.X.Offset
        FullSize.Height = MainFrame.Size.Y.Offset
        
        local targetWidth = math.min(200, MainFrame.Size.X.Offset)
        TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
            Size = UDim2.new(0, targetWidth, 0, MinimizedSize)
        }):Play()
        
        ContentContainer.Visible = false
        Title.Text = "👥 Joueurs ▼"
        MinimizeButton.Text = "⊕"
    else
        TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
            Size = UDim2.new(0, FullSize.Width, 0, FullSize.Height)
        }):Play()
        
        task.wait(0.3)
        ContentContainer.Visible = true
        Title.Text = "👥 Joueurs Connectés"
        MinimizeButton.Text = "−"
    end
end

