-- ===== Rafraîchir la liste avec filtre =====
local function RefreshPlayerList(filterText)
    for _, child in ipairs(ScrollFrame:GetChildren()) do
        if child:IsA("Frame") and child.Name:match("PlayerItem_") then
            child:Destroy()
        end
    end

    local playerList = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            table.insert(playerList, player)
        end
    end

    if filterText and filterText ~= "" then
        local lowerFilter = filterText:lower()
        local filtered = {}
        for _, p in ipairs(playerList) do
            if p.DisplayName:lower():find(lowerFilter) or p.Name:lower():find(lowerFilter) then
                table.insert(filtered, p)
            end
        end
        playerList = filtered
    end

    table.sort(playerList, function(a, b)
        return a.DisplayName < b.DisplayName
    end)

    for i, player in ipairs(playerList) do
        CreatePlayerItem(player, i)
    end

    ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, (#playerList * 49) + 10)
    UpdateAllTeleportButtons()
end

