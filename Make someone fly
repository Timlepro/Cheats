                BackgroundTransparency = 0.1,
                BackgroundColor3 = Color3.fromRGB(60, 160, 240)
            }):Play()
        end)

        TeleportButton.MouseLeave:Connect(function()
            TweenService:Create(TeleportButton, TweenInfo.new(0.2), {
                BackgroundTransparency = 0.2,
                BackgroundColor3 = Color3.fromRGB(40, 120, 200)
            }):Play()
        end)
    end

    -- Fonction du bouton de téléportation
    TeleportButton.MouseButton1Click:Connect(function()
        pcall(function()
            -- Animation de clic
            TweenService:Create(TeleportButton, TweenInfo.new(0.1), {
                Size = UDim2.new(0, btnW-5, 0, btnH-3)
            }):Play()
            task.wait(0.1)
            TweenService:Create(TeleportButton, TweenInfo.new(0.1), {
                Size = UDim2.new(0, btnW, 0, btnH)
            }):Play()

            if InfiniteTeleport.Active and InfiniteTeleport.TargetPlayer == player then
                -- Désactiver la téléportation si déjà active sur ce joueur
                StopInfiniteTeleport()
                TeleportButton.Text = "🔗 Téléporter"
                TeleportButton.BackgroundColor3 = Color3.fromRGB(40, 120, 200)
                TeleportButton.TextColor3 = Color3.fromRGB(180, 220, 255)
            else
                -- Activer la téléportation
                StartInfiniteTeleport(player)
                TeleportButton.Text = "⏹ Arrêter"
                TeleportButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
                TeleportButton.TextColor3 = Color3.fromRGB(255, 200, 200)
            end
        end)
    end)

    return ItemFrame
end

-- Fonction pour mettre à jour la liste des joueurs
local function UpdatePlayerList()
    -- Supprimer les anciens éléments (sauf le UIListLayout)
    for _, child in ipairs(ScrollFrame:GetChildren()) do
        if child:IsA("Frame") and child.Name:match("PlayerItem_") then
            child:Destroy()
        end
    end
    
    -- Récupérer tous les joueurs sauf le joueur local
    local playerList = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            table.insert(playerList, player)
        end
    end
    
    -- Trier par nom
    table.sort(playerList, function(a, b)
        return a.Name < b.Name
    end)
    
    -- Créer les éléments
    for i, player in ipairs(playerList) do
        CreatePlayerItem(player, i)
    end
    
    -- Mettre à jour le CanvasSize
    ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, (#playerList * 53) + 10)
end

-- Appel initial
UpdatePlayerList()

-- Mettre à jour la liste quand des joueurs rejoignent/quittent
Players.PlayerAdded:Connect(function(newPlayer)
    -- NE PAS arrêter la téléportation quand un joueur rejoint
    UpdatePlayerList()
end)

Players.PlayerRemoving:Connect(function(player)
    -- Si le joueur cible quitte, arrêter la téléportation
    if InfiniteTeleport.Active and InfiniteTeleport.TargetPlayer == player then
        StopInfiniteTeleport()
    end
    UpdatePlayerList()
end)

-- Fonction pour basculer le mode réduit (comme dans l'exemple)
local function ToggleMinimize()
    IsMinimized = not IsMinimized
    
    if IsMinimized then
        -- Sauvegarder la taille actuelle
        FullSize.Width = MainFrame.Size.X.Offset
        FullSize.Height = MainFrame.Size.Y.Offset
        
        -- Réduire à la barre de titre
        local targetWidth = math.min(200, MainFrame.Size.X.Offset)
        TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
            Size = UDim2.new(0, targetWidth, 0, MinimizedSize)
        }):Play()
        
        ContentContainer.Visible = false
        ToggleButton.ImageColor3 = Color3.fromRGB(50, 200, 50)
        Title.Text = "👥 Joueurs ▼"
    else
        -- Restaurer la taille
        TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
            Size = UDim2.new(0, FullSize.Width, 0, FullSize.Height)
        }):Play()
        
        task.wait(0.3)
        ContentContainer.Visible = true
        ToggleButton.ImageColor3 = Color3.fromRGB(200, 200, 50)
        Title.Text = "👥 Joueurs Connectés"
    end
end

-- Fonction de déplacement
local function StartDrag(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        Dragging = true
        DragStart = input.Position
        StartPos = MainFrame.Position
    end
end

local function UpdateDrag(input)
    if Dragging then
        local delta = input.Position - DragStart
        MainFrame.Position = UDim2.new(
            StartPos.X.Scale,
            StartPos.X.Offset + delta.X,
            StartPos.Y.Scale,
            StartPos.Y.Offset + delta.Y
        )
    end
end

local function EndDrag()
    Dragging = false
end

-- Gestion des événements de déplacement
TitleBar.InputBegan:Connect(StartDrag)
TitleBar.InputChanged:Connect(UpdateDrag)
TitleBar.InputEnded:Connect(EndDrag)

