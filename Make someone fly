-- Taille très réduite (moins de 30% de l'écran)
local function GetAdaptiveSize()
    local screenSize = workspace.CurrentCamera.ViewportSize
    local width = math.min(0.25, 0.25) * screenSize.X  -- 25% de l'écran
    local height = math.min(0.30, 0.30) * screenSize.Y
    if IsMobile or IsSmallScreen then
        width = math.min(0.4, 0.4) * screenSize.X
        height = math.min(0.5, 0.5) * screenSize.Y
    end
    -- Tailles minimales pour lisibilité
    width = math.max(280, width)
    height = math.max(300, height)
    return width, height
end

