-- ===== Gestion du slider =====
local MIN_DISTANCE = -50
local MAX_DISTANCE = 50

local function UpdateDistanceDisplay(value)
    if value >= 0 then
        DistanceLabel.Text = "📏 Dist: " .. string.format("%.1f", value) .. " sous"
    else
        DistanceLabel.Text = "📏 Dist: " .. string.format("%.1f", math.abs(value)) .. " au-dessus"
    end
    DistanceBox.Text = string.format("%.1f", value)
end

local function UpdateDistance(value)
    local normalized = math.clamp((value - MIN_DISTANCE) / (MAX_DISTANCE - MIN_DISTANCE), 0, 1)
    SliderFill.Size = UDim2.new(normalized, 0, 1, 0)
    SliderButton.Position = UDim2.new(normalized, -7, 0.5, -7)
    InfiniteTeleport.Distance = value
    UpdateDistanceDisplay(value)
end

local isDraggingSlider = false

local function StartSliderDrag(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        isDraggingSlider = true
        UpdateSliderPosition(input)
    end
end

local function UpdateSliderPosition(input)
    if not isDraggingSlider then return end
    local trackPos = SliderTrack.AbsolutePosition
    local trackSize = SliderTrack.AbsoluteSize
    local mouseX = input.Position.X
    local normalized = math.clamp((mouseX - trackPos.X) / trackSize.X, 0, 1)
    local value = MIN_DISTANCE + normalized * (MAX_DISTANCE - MIN_DISTANCE)
    UpdateDistance(value)
end

local function EndSliderDrag()
    isDraggingSlider = false
end

SliderButton.InputBegan:Connect(StartSliderDrag)
SliderButton.InputChanged:Connect(UpdateSliderPosition)
SliderButton.InputEnded:Connect(EndSliderDrag)

SliderTrack.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        isDraggingSlider = true
        UpdateSliderPosition(input)
    end
end)
SliderTrack.InputChanged:Connect(UpdateSliderPosition)
SliderTrack.InputEnded:Connect(EndSliderDrag)

DistanceBox.FocusLost:Connect(function()
    local val = tonumber(DistanceBox.Text)
    if val then
        val = math.clamp(val, MIN_DISTANCE, MAX_DISTANCE)
        UpdateDistance(val)
    else
        DistanceBox.Text = string.format("%.1f", InfiniteTeleport.Distance)
    end
end)

