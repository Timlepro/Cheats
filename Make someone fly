-- Dimensions adaptatives
local function GetAdaptiveSize()
    local screenSize = workspace.CurrentCamera.ViewportSize
    local width = math.min(400, screenSize.X * 0.9)
    local height = math.min(500, screenSize.Y * 0.85)
    
    if IsMobile or IsSmallScreen then
        width = math.min(350, screenSize.X * 0.92)
        height = math.min(450, screenSize.Y * 0.8)
    end
    
    return width, height
end

local function GetAdaptiveFontSize()
    if IsMobile or IsSmallScreen then
        return 14
    end
    return 18
end

local function GetAdaptiveButtonSize()
    if IsMobile or IsSmallScreen then
        return 60, 28
    end
    return 70, 32
end

