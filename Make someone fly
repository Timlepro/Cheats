Players.PlayerRemoving:Connect(function(player)
    if InfiniteTeleport.Active and InfiniteTeleport.TargetPlayer == player then
        StopInfiniteTeleport()
    end
    RefreshPlayerList(SearchBox.Text)
end)

-- ===== Mode réduit =====
local function ToggleMinimize()
    IsMinimized = not IsMinimized
    if IsMinimized then
        FullSize.Width = MainFrame.Size.X.Offset
        FullSize.Height = MainFrame.Size.Y.Offset
        local targetWidth = math.min(160, MainFrame.Size.X.Offset)
        TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
            Size = UDim2.new(0, targetWidth, 0, MinimizedSize)
        }):Play()
        ContentContainer.Visible = false
        Title.Text = "👥 Joueurs ▼"
        MinimizeButton.Text = "+"
    else
        TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
            Size = UDim2.new(0, FullSize.Width, 0, FullSize.Height)
        }):Play()
        task.wait(0.3)
        ContentContainer.Visible = true
        Title.Text = "👥 Joueurs"
        MinimizeButton.Text = "−"
    end
end

local function DestroyGUI()
    if InfiniteTeleport.Active then StopInfiniteTeleport() end
    ScreenGui:Destroy()
end

local function ShowMainFrame()
    MainFrame.Visible = true
    FloatButton.Visible = false
    if SavedPosition then MainFrame.Position = SavedPosition end
    if IsMinimized then
        MinimizeButton.Text = "+"
        Title.Text = "👥 Joueurs ▼"
        ContentContainer.Visible = false
    else
        MinimizeButton.Text = "−"
        Title.Text = "👥 Joueurs"
        ContentContainer.Visible = true
    end
end

local function HideMainFrame()
    SavedPosition = MainFrame.Position
    MainFrame.Visible = false
    FloatButton.Visible = true
    FloatButton.Size = UDim2.new(0, 32, 0, 32)
    FloatButton.Position = UDim2.new(0.5, -16, 0.02, 0)
    TweenService:Create(FloatButton, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
        Size = UDim2.new(0, 40, 0, 40),
        Position = UDim2.new(0.5, -20, 0.02, 0)
    }):Play()
end

-- Déplacement de la fenêtre
local function StartDrag(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        Dragging = true
        DragStart = input.Position
        StartPos = MainFrame.Position
    end
end
local function UpdateDrag(input)
    if Dragging then
        local delta = input.Position - DragStart
        MainFrame.Position = UDim2.new(
            StartPos.X.Scale,
            StartPos.X.Offset + delta.X,
            StartPos.Y.Scale,
            StartPos.Y.Offset + delta.Y
        )
    end
end
local function EndDrag()
    Dragging = false
end

TitleBar.InputBegan:Connect(StartDrag)
TitleBar.InputChanged:Connect(UpdateDrag)
TitleBar.InputEnded:Connect(EndDrag)

MinimizeButton.MouseButton1Click:Connect(ToggleMinimize)
CloseButton.MouseButton1Click:Connect(DestroyGUI)
FloatButton.MouseButton1Click:Connect(ShowMainFrame)

ShowMainFrame()

_G.ShowTeleportGUI = ShowMainFrame

ScreenGui.AncestryChanged:Connect(function()
    if not ScreenGui.Parent then
        task.wait(1)
        if not ScreenGui.Parent then
            ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
        end
    end
end)

-- Redimensionnement
RunService.RenderStepped:Connect(function()
    local currentSize = workspace.CurrentCamera.ViewportSize
    local isNowSmall = currentSize.X < 600
    if isNowSmall ~= IsSmallScreen then
        IsSmallScreen = isNowSmall
        IsMobile = UserInputService.TouchEnabled
        if FloatButton.Visible then
            FloatButton.Position = UDim2.new(0.5, -20, 0.02, 0)
        end
        UpdateMainFrame()
        RefreshPlayerList(SearchBox.Text)
    end
end)

