DistanceBox.FocusLost:Connect(function(enterPressed)
    local val = tonumber(DistanceBox.Text)
    if val then
        val = math.clamp(val, MIN_DISTANCE, MAX_DISTANCE)
        UpdateDistance(val)
    else
