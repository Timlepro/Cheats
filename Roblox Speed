-- ===== GESTION DES PRÉFÉRENCES =====
local function SaveSettings()
    local data = {
        Enabled = isEnabled,
        Speed = targetSpeed,
        FloatPosition = {}
    }
    if FloatButton then
        data.FloatPosition = {
            X = FloatButton.Position.X.Scale or 0.5,
            XOffset = FloatButton.Position.X.Offset or -25,
            Y = FloatButton.Position.Y.Scale or 0.02,
            YOffset = FloatButton.Position.Y.Offset or 0
        }
    else
        data.FloatPosition = { X = 0.5, XOffset = -25, Y = 0.02, YOffset = 0 }
    end
    local json = HttpService:JSONEncode(data)
    pcall(function() writefile(CONFIG_FILE, json) end)
end

local function LoadSettings()
    if not isfile(CONFIG_FILE) then SaveSettings() return end
    local success, content = pcall(readfile, CONFIG_FILE)
    if not success then SaveSettings() return end
    local decoded = HttpService:JSONDecode(content)
    if decoded then
        isEnabled = decoded.Enabled or false
        targetSpeed = decoded.Speed or DEFAULT_SPEED
        if decoded.FloatPosition and FloatButton then
            FloatButton.Position = UDim2.new(
                decoded.FloatPosition.X or 0.5,
                decoded.FloatPosition.XOffset or -25,
                decoded.FloatPosition.Y or 0.02,
                decoded.FloatPosition.YOffset or 0
            )
        end
    end
end

