-- ===== ADAPTATION AU REDIMENSIONNEMENT DE L'ÉCRAN =====
RunService.RenderStepped:Connect(function()
    local view = workspace.CurrentCamera.ViewportSize
    local newSmall = view.X < 600
    if newSmall ~= IsSmallScreen then
        IsSmallScreen = newSmall
        IsMobile = UserInputService.TouchEnabled
        UpdateMainFrameSize()
        local fs = GetAdaptiveFontSize()
        Title.TextSize = fs
        SpeedLabel.TextSize = fs
        SpeedBox.TextSize = fs
        ToggleButton.TextSize = fs - 2
        StatusLabel.TextSize = fs - 3
    end
end)

-- Exposer des fonctions pour une éventuelle manipulation externe
_G.SetSpeed = function(value)
    if value and value > 0 then
        targetSpeed = math.floor(value)
        SpeedBox.Text = tostring(targetSpeed)
        SaveSettings()
        if isEnabled then ApplySpeed() end
    end
end
_G.EnableSpeed = function(enable)
    isEnabled = enable
    ToggleButton.Text = isEnabled and "✅ ON" or "❌ OFF"
    ToggleButton.BackgroundColor3 = isEnabled and Color3.fromRGB(40, 180, 80) or Color3.fromRGB(180, 40, 40)
    ToggleButton.BorderColor3 = isEnabled and Color3.fromRGB(40, 180, 80) or Color3.fromRGB(180, 40, 40)
    ToggleButton.TextColor3 = isEnabled and Color3.fromRGB(180, 255, 200) or Color3.fromRGB(255, 180, 180)
    StatusLabel.Text = isEnabled and "✔ Actif (réappliqué toutes les secondes)" or "⏸ Désactivé"
    StatusLabel.TextColor3 = isEnabled and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(200, 200, 200)
    SaveSettings()
    if isEnabled then ApplySpeed() end
end
