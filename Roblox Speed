local IsMobile = UserInputService.TouchEnabled
local IsSmallScreen = workspace.CurrentCamera.ViewportSize.X < 600

local function GetAdaptiveSize()
    local screen = workspace.CurrentCamera.ViewportSize
    local w = math.min(380, screen.X * 0.9)
    local h = math.min(280, screen.Y * 0.65)
    if IsMobile or IsSmallScreen then
        w = math.min(340, screen.X * 0.92)
        h = math.min(250, screen.Y * 0.6)
    end
    return w, h
end

local function GetAdaptiveFontSize()
    return (IsMobile or IsSmallScreen) and 13 or 17
end

