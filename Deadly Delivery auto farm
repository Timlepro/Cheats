local toggleButton = Instance.new("TextButton")
toggleButton.Size = UDim2.new(0.72, 0, 0.65, 0)
toggleButton.Position = UDim2.new(0.42, 0, 0.5, 0)
toggleButton.AnchorPoint = Vector2.new(0.5, 0.5)
