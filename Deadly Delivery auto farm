--==================================================
-- BOUCLE PRINCIPALE
--==================================================
local function StartFarm()
	if farming then return end
	farming = true
	Debug("Auto-farm démarré (mode Prompt E)")

	if Step1_OpenAllContainers() and autoFarmEnabled and not destroyed then
		Step2_CollectAndDrop()
		if autoFarmEnabled and not destroyed then
			Step3_UpgradeItems()
		end
	end

	while autoFarmEnabled and not destroyed do
		task.wait(0.5)
	end

	currentTargetModel = nil
	currentTargetPart = nil
	UnfreezePlayer()
	if camera.CameraType == Enum.CameraType.Scriptable then
		camera.CameraType = oldCameraType
	end
	farming = false
	Debug("Auto-farm arrêté")
end

--==================================================
-- CONTROLES
--==================================================
local function RefreshButton()
	if autoFarmEnabled then
		toggleButton.Text = "■ ARRÊTER"
		toggleButton.BackgroundColor3 = Color3.fromRGB(50, 150, 70)
	else
		toggleButton.Text = "▶ DÉMARRER"
		toggleButton.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
	end
end

local function SetAutoFarm(state)
	autoFarmEnabled = state
	RefreshButton()
	if autoFarmEnabled then
		task.spawn(StartFarm)
	else
		currentTargetModel = nil
		currentTargetPart = nil
		UnfreezePlayer()
		if camera.CameraType == Enum.CameraType.Scriptable then
			camera.CameraType = oldCameraType
		end
	end
end

local function DestroyAll()
	destroyed = true
	autoFarmEnabled = false
	currentTargetModel = nil
	currentTargetPart = nil
	UnfreezePlayer()
	for _, conn in ipairs(connections) do
		if conn then conn:Disconnect() end
	end
	if screenGui then screenGui:Destroy() end
	script:Destroy()
end

