local isBusy = false
local scriptDestroyed = false

local MOVE_SPEED = 350
local UNDER_OFFSET = 4
local INTERACTION_TIME = 1.5
local SPAM_DELAY = 0.08

local usedItems = {}
local connections = {}

local currentLockPart = nil

local oldCameraType = camera.CameraType
local oldWalkSpeed = nil
local oldJumpPower = nil
local oldJumpHeight = nil
local oldAutoRotate = nil

local allowedNames = {
	Cabinet = true,
	Crate = true,
	OilBucket = true,
}

