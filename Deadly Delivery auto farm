local function OpenContainer()
	print("OpenContainer")
end

local function DropItem()
	print("DropItem")
end

local function SetAutoFarm(state)
	autoFarmEnabled = state

	if autoFarmEnabled then
		toggleButton.Text = "Auto Farm : ON"
		toggleButton.BackgroundColor3 = Color3.fromRGB(40, 150, 70)
	else
		toggleButton.Text = "Auto Farm : OFF"
		toggleButton.BackgroundColor3 = Color3.fromRGB(160, 40, 40)
	end
end

local function ConnectButton(buttonObject, callback)
	if not buttonObject then return end
	if not buttonObject:IsA("GuiButton") then return end

	buttonObject.Active = true

	local connection = buttonObject.Activated:Connect(function()
		if destroyed then return end
		callback()
	end)

	table.insert(buttonConnections, connection)
end

ConnectButton(toggleButton, function()
	SetAutoFarm(not autoFarmEnabled)
end)

ConnectButton(closeButton, function()
	destroyed = true
	autoFarmEnabled = false

	for _, connection in ipairs(buttonConnections) do
		if connection then
			connection:Disconnect()
		end
	end

	gui:Destroy()
	script:Destroy()
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if destroyed then return end
	if gameProcessed then return end

	if input.KeyCode == Enum.KeyCode.E then
		OpenContainer()
	end

	if input.KeyCode == Enum.KeyCode.G then
		DropItem()
	end
end)

task.spawn(function()
	while not destroyed do
		local touchGui = playerGui:FindFirstChild("Touch")

		if touchGui then
			local rightFrame = touchGui:FindFirstChild("Right")

			if rightFrame then
				local interactButton = rightFrame:FindFirstChild("InteractButton")
				local dropButton = rightFrame:FindFirstChild("DropButton")

				if interactButton then
					ConnectButton(interactButton, OpenContainer)
				end

				if dropButton then
					ConnectButton(dropButton, DropItem)
				end

				break
			end
		end

		task.wait(0.5)
	end
end)
