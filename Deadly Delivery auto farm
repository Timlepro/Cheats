local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local touchGui = playerGui:WaitForChild("Touch")
local rightFrame = touchGui:WaitForChild("Right")

local interactButton = rightFrame:WaitForChild("InteractButton")
local dropButton = rightFrame:WaitForChild("DropButton")

local autoFarmEnabled = false

local gui = Instance.new("ScreenGui")
gui.Name = "AutoFarmUI"
gui.ResetOnSpawn = false
gui.Parent = playerGui

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 230, 0, 70)
frame.Position = UDim2.new(0.5, 0, 0.14, 0)
frame.AnchorPoint = Vector2.new(0.5, 0.5)
frame.BackgroundColor3 = Color3.fromRGB(33, 33, 33)
frame.BorderSizePixel = 0
frame.Parent = gui

local frameCorner = Instance.new("UICorner")
frameCorner.CornerRadius = UDim.new(1, 0)
frameCorner.Parent = frame

local toggleButton = Instance.new("TextButton")
toggleButton.Size = UDim2.new(0.72, 0, 0.65, 0)
toggleButton.Position = UDim2.new(0.42, 0, 0.5, 0)
toggleButton.AnchorPoint = Vector2.new(0.5, 0.5)
toggleButton.BackgroundColor3 = Color3.fromRGB(160, 40, 40)
toggleButton.BorderSizePixel = 0
toggleButton.Text = "Auto Farm : OFF"
toggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleButton.TextScaled = true
toggleButton.Font = Enum.Font.GothamBold
toggleButton.Parent = frame

local toggleCorner = Instance.new("UICorner")
toggleCorner.CornerRadius = UDim.new(1, 0)
toggleCorner.Parent = toggleButton

local closeButton = Instance.new("TextButton")
closeButton.Size = UDim2.new(0.18, 0, 0.65, 0)
closeButton.Position = UDim2.new(0.88, 0, 0.5, 0)
closeButton.AnchorPoint = Vector2.new(0.5, 0.5)
closeButton.BackgroundColor3 = Color3.fromRGB(180, 40, 40)
closeButton.BorderSizePixel = 0
closeButton.Text = "X"
closeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
closeButton.TextScaled = true
closeButton.Font = Enum.Font.GothamBold
closeButton.Parent = frame

local closeCorner = Instance.new("UICorner")
closeCorner.CornerRadius = UDim.new(1, 0)
closeCorner.Parent = closeButton

local function OpenContainer()
	print("OpenContainer")
end

local function DropItem()
	print("DropItem")
end

local function SetAutoFarm(state)
	autoFarmEnabled = state

	if autoFarmEnabled then
		toggleButton.Text = "Auto Farm : ON"
		toggleButton.BackgroundColor3 = Color3.fromRGB(40, 150, 70)
	else
		toggleButton.Text = "Auto Farm : OFF"
		toggleButton.BackgroundColor3 = Color3.fromRGB(160, 40, 40)
	end
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end

	if input.KeyCode == Enum.KeyCode.E then
		OpenContainer()
	end

	if input.KeyCode == Enum.KeyCode.G then
		DropItem()
	end
end)

interactButton.MouseButton1Click:Connect(function()
	OpenContainer()
end)

dropButton.MouseButton1Click:Connect(function()
	DropItem()
end)

toggleButton.MouseButton1Click:Connect(function()
	SetAutoFarm(not autoFarmEnabled)
end)

closeButton.MouseButton1Click:Connect(function()
	gui:Destroy()
	script:Destroy()
end)
