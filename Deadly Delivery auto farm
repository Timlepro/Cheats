local function getCharacter()
	return player.Character or player.CharacterAdded:Wait()
end

local function getHumanoid()
	local character = getCharacter()
	return character:WaitForChild("Humanoid")
end

local function getRootPart()
	local character = getCharacter()
	return character:WaitForChild("HumanoidRootPart")
end

local function saveMovement()
	local humanoid = getHumanoid()

	if oldWalkSpeed == nil then
		oldWalkSpeed = humanoid.WalkSpeed
		oldJumpPower = humanoid.JumpPower
		oldJumpHeight = humanoid.JumpHeight
		oldAutoRotate = humanoid.AutoRotate
	end
end

local function freezePlayer()
	local humanoid = getHumanoid()
	local rootPart = getRootPart()

	saveMovement()

	humanoid.WalkSpeed = 0
	humanoid.JumpPower = 0
	humanoid.JumpHeight = 0
	humanoid.AutoRotate = false

	rootPart.AssemblyLinearVelocity = Vector3.zero
	rootPart.AssemblyAngularVelocity = Vector3.zero
end

local function unfreezePlayer()
	local humanoid = getHumanoid()

	if oldWalkSpeed ~= nil then
		humanoid.WalkSpeed = oldWalkSpeed
		humanoid.JumpPower = oldJumpPower
		humanoid.JumpHeight = oldJumpHeight
		humanoid.AutoRotate = oldAutoRotate
	end

	oldWalkSpeed = nil
	oldJumpPower = nil
	oldJumpHeight = nil
	oldAutoRotate = nil
end

local function disablePlayerCollisions()
	local character = getCharacter()

	for _, object in ipairs(character:GetDescendants()) do
		if object:IsA("BasePart") then
			object.CanCollide = false
		end
	end
end

local function isValidModel(model)
	if not model:IsA("Model") then
		return false
	end

	local nameType, number = model.Name:match("^(%a+)_([0-9]+)$")

	if not nameType or not number then
		return false
	end

	return allowedNames[nameType] == true
end

local function getInteractiveFolder()
	local gameSystem = workspace:FindFirstChild("GameSystem")
	if not gameSystem then return nil end

	return gameSystem:FindFirstChild("InteractiveItem")
end

local function getInteractablePart(model)
	local part = model:FindFirstChild("Interactable", true)

	if part and part:IsA("BasePart") then
		return part
	end

	return nil
end

local function getPrompt(model, interactablePart)
	local prompt = interactablePart:FindFirstChildWhichIsA("ProximityPrompt", true)

	if prompt then
		return prompt
	end

	return model:FindFirstChildWhichIsA("ProximityPrompt", true)
end

local function setupPromptForPC(prompt)
	if not prompt then return end

	pcall(function()
		prompt.KeyboardKeyCode = Enum.KeyCode.E
	end)

	pcall(function()
		prompt.RequiresLineOfSight = false
	end)

	pcall(function()
		prompt.MaxActivationDistance = 20
	end)
end

local function getAllTargets()
	local folder = getInteractiveFolder()
	local targets = {}

	if not folder then
		warn("Folder introuvable : workspace.GameSystem.InteractiveItem")
		return targets
	end

	for _, model in ipairs(folder:GetChildren()) do
		if isValidModel(model) and not usedItems[model] then
			local interactablePart = getInteractablePart(model)

			if interactablePart then
				table.insert(targets, {
					model = model,
					part = interactablePart,
				})
			end
		end
	end

	return targets
end

local function getUnderCFrame(part)
	local targetPosition = part.Position - Vector3.new(0, UNDER_OFFSET, 0)

	-- Le joueur regarde la part au-dessus de lui
	return CFrame.lookAt(targetPosition, part.Position)
end

local function moveFastUnderPart(part)
	local rootPart = getRootPart()

	local targetCFrame = getUnderCFrame(part)
	local distance = (rootPart.Position - targetCFrame.Position).Magnitude
	local duration = math.clamp(distance / MOVE_SPEED, 0.05, 1.5)

	local tween = TweenService:Create(
		rootPart,
		TweenInfo.new(duration, Enum.EasingStyle.Linear),
		{ CFrame = targetCFrame }
	)

	tween:Play()
	tween.Completed:Wait()

	rootPart.CFrame = targetCFrame
end

local function spamPrompt(prompt)
	if not prompt then return end

	local startTime = os.clock()

	while autoFarm and not scriptDestroyed and os.clock() - startTime < INTERACTION_TIME do
		pcall(function()
			prompt:InputHoldBegin()
		end)

		task.wait(SPAM_DELAY)

		pcall(function()
			prompt:InputHoldEnd()
		end)

		task.wait(SPAM_DELAY)
	end
end

local function interactWithItem(model, interactablePart)
	local prompt = getPrompt(model, interactablePart)

	setupPromptForPC(prompt)

	currentLockPart = interactablePart
	freezePlayer()

	if prompt then
		spamPrompt(prompt)
	else
		warn("Aucun ProximityPrompt trouvé dans :", model.Name)
		task.wait(0.5)
	end

	currentLockPart = nil
	unfreezePlayer()

	if interactablePart and interactablePart.Parent then
		interactablePart:Destroy()
	end

	usedItems[model] = true
end

local renderConnection = RunService.RenderStepped:Connect(function()
	if scriptDestroyed then return end

	if autoFarm then
		disablePlayerCollisions()
	end

	if currentLockPart and currentLockPart.Parent then
		local rootPart = getRootPart()
		local lockCFrame = getUnderCFrame(currentLockPart)

		rootPart.CFrame = lockCFrame
		rootPart.AssemblyLinearVelocity = Vector3.zero
		rootPart.AssemblyAngularVelocity = Vector3.zero

		camera.CameraType = Enum.CameraType.Scriptable

		local cameraPosition = rootPart.Position + Vector3.new(0, 1.5, 0)
		local lookPosition = currentLockPart.Position + Vector3.new(0, 1, 0)

		camera.CFrame = CFrame.lookAt(cameraPosition, lookPosition)
	else
		if not scriptDestroyed then
			camera.CameraType = oldCameraType
		end
	end
end)

table.insert(connections, renderConnection)

local function startAutoFarm()
	if isBusy then return end
	isBusy = true

	while autoFarm and not scriptDestroyed do
		local targets = getAllTargets()

		if #targets == 0 then
			task.wait(0.4)
		else
			for _, target in ipairs(targets) do
				if not autoFarm or scriptDestroyed then
					break
				end

				if target.model and target.model.Parent and target.part and target.part.Parent then
					disablePlayerCollisions()

					moveFastUnderPart(target.part)

					task.wait(0.1)

					interactWithItem(target.model, target.part)

					task.wait(0.2)
				end
			end
		end

		task.wait(0.1)
	end

	currentLockPart = nil
	unfreezePlayer()
	camera.CameraType = oldCameraType

	isBusy = false
end

local function destroyScript()
	scriptDestroyed = true
	autoFarm = false
	currentLockPart = nil

	unfreezePlayer()

	camera.CameraType = oldCameraType

	for _, connection in ipairs(connections) do
		if connection and connection.Disconnect then
			connection:Disconnect()
		end
	end

	if gui then
		gui:Destroy()
	end

	script:Destroy()
end

local toggleConnection = button.MouseButton1Click:Connect(function()
	if scriptDestroyed then return end

	autoFarm = not autoFarm

	if autoFarm then
		button.Text = "Auto Farm : ON"
		button.BackgroundColor3 = Color3.fromRGB(40, 150, 70)

		task.spawn(startAutoFarm)
	else
		button.Text = "Auto Farm : OFF"
		button.BackgroundColor3 = Color3.fromRGB(160, 40, 40)

		currentLockPart = nil
		unfreezePlayer()
		camera.CameraType = oldCameraType
	end
end)

table.insert(connections, toggleConnection)

local closeConnection = closeButton.MouseButton1Click:Connect(function()
	destroyScript()
end)

table.insert(connections, closeConnection)
