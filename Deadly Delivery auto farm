-- REMOTE EVENT
--==================================================

local function FindRemoteEvent()
	local found = ReplicatedStorage:FindFirstChild(remoteName, true)

	if found and found:IsA("RemoteEvent") then
		remoteEvent = found
		Debug("Remote trouvé : " .. found:GetFullName())
		return found
	end

	Debug("Remote introuvable : " .. remoteName)
	return nil
end

local function FireInteractRemote(model, part)
	if not remoteEvent then
		FindRemoteEvent()
	end

	if not remoteEvent then
		return false
	end

	Debug("FireServer sur " .. model.Name)

	local success, err = pcall(function()
		--==================================================
		-- À MODIFIER ICI SI TON REMOTE ATTEND AUTRE CHOSE
		--==================================================

		remoteEvent:FireServer(model)

		-- Exemples possibles si le premier ne marche pas :
		-- remoteEvent:FireServer(part)
		-- remoteEvent:FireServer("Open", model)
		-- remoteEvent:FireServer("Interact", model)
		-- remoteEvent:FireServer(model, "Open")
		-- remoteEvent:FireServer(part, "Open")
	end)

	if not success then
		Debug("Erreur FireServer : " .. tostring(err))
		return false
	end

	return true
end

