local function TriggerInteract()
	print("INTERACT")
end

local function TriggerDrop()
	print("DROP")
end

local function SetAutoFarm(state)
	autoFarmEnabled = state

	if autoFarmEnabled then
		toggleButton.Text = "Auto Farm : ON"
		toggleButton.BackgroundColor3 = Color3.fromRGB(40, 150, 70)
	else
		toggleButton.Text = "Auto Farm : OFF"
		toggleButton.BackgroundColor3 = Color3.fromRGB(160, 40, 40)
	end
end

local function ConnectFramePress(frameObject, callback)
	if not frameObject then return end
	if not frameObject:IsA("GuiObject") then return end

	frameObject.Active = true

	local connection = frameObject.InputBegan:Connect(function(input)
		if destroyed then return end

		if input.UserInputType == Enum.UserInputType.Touch then
			callback()
		end

		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			callback()
		end
	end)

	table.insert(connections, connection)
end

local function DestroyAll()
	destroyed = true
	autoFarmEnabled = false

	for _, connection in ipairs(connections) do
		if connection then
			connection:Disconnect()
		end
	end

	if screenGui then
		screenGui:Destroy()
	end

	script:Destroy()
end

table.insert(connections, toggleButton.Activated:Connect(function()
	if destroyed then return end
	SetAutoFarm(not autoFarmEnabled)
end))

table.insert(connections, closeButton.Activated:Connect(function()
	DestroyAll()
end))

table.insert(connections, UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if destroyed then return end
	if gameProcessed then return end

	if input.KeyCode == Enum.KeyCode.E then
		TriggerInteract()
	end

	if input.KeyCode == Enum.KeyCode.G then
		TriggerDrop()
	end
end))

task.spawn(function()
	while not destroyed do
		local touchGui = playerGui:FindFirstChild("Touch")

		if touchGui then
			local rightFrame = touchGui:FindFirstChild("Right")

			if rightFrame then
				local interactFrame = rightFrame:FindFirstChild("InteractButton")
				local dropFrame = rightFrame:FindFirstChild("DropButton")

				if interactFrame then
					ConnectFramePress(interactFrame, TriggerInteract)
				end

				if dropFrame then
					ConnectFramePress(dropFrame, TriggerDrop)
				end

				break
			end
		end

		task.wait(0.25)
	end
end)

task.spawn(function()
	while not destroyed do
		if autoFarmEnabled then
			TriggerInteract()
			task.wait(0.15)
		else
			task.wait(0.25)
		end
	end
end)
