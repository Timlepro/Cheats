local function GetCharacter()
	return player.Character or player.CharacterAdded:Wait()
end

local function GetHumanoid()
	return GetCharacter():WaitForChild("Humanoid")
end

local function GetRoot()
	return GetCharacter():WaitForChild("HumanoidRootPart")
end

local function SaveMovement()
	local humanoid = GetHumanoid()

	if oldWalkSpeed == nil then
		oldWalkSpeed = humanoid.WalkSpeed
		oldJumpPower = humanoid.JumpPower
		oldJumpHeight = humanoid.JumpHeight
		oldAutoRotate = humanoid.AutoRotate
	end
end

local function FreezePlayer()
	local humanoid = GetHumanoid()
	local root = GetRoot()

	SaveMovement()

	humanoid.WalkSpeed = 0
	humanoid.JumpPower = 0
	humanoid.JumpHeight = 0
	humanoid.AutoRotate = false

	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero
end

local function UnfreezePlayer()
	local humanoid = GetHumanoid()

	if oldWalkSpeed ~= nil then
		humanoid.WalkSpeed = oldWalkSpeed
		humanoid.JumpPower = oldJumpPower
		humanoid.JumpHeight = oldJumpHeight
		humanoid.AutoRotate = oldAutoRotate
	end

	oldWalkSpeed = nil
	oldJumpPower = nil
	oldJumpHeight = nil
	oldAutoRotate = nil
end

--==================================================
-- RECHERCHE OBJETS
--==================================================

local function GetFolder()
	local gameSystem = workspace:FindFirstChild("GameSystem")

	if not gameSystem then
		Debug("GameSystem introuvable")
		return nil
	end

	local folder = gameSystem:FindFirstChild("InteractiveItem")

	if not folder then
		Debug("InteractiveItem introuvable")
		return nil
	end

	return folder
end

local function IsNameInList(name)
	for _, validName in ipairs(contenants) do
		if name == validName then
			return true
		end
	end

	return false
end

local function IsValidModel(model)
	if not model:IsA("Model") then
		return false
	end

	local nameType, number = model.Name:match("^(%a+)_([0-9]+)$")

	if not nameType then
		return false
	end

	if not number then
		return false
	end

	return IsNameInList(nameType)
end

local function GetInteractablePart(model)
	local part = model:FindFirstChild("Interactable", true)

	if part and part:IsA("BasePart") then
		return part
	end

	return nil
end

local function GetTargets()
	local folder = GetFolder()
	local targets = {}

	if not folder then
		return targets
	end

	for _, model in ipairs(folder:GetChildren()) do
		if IsValidModel(model) and not skippedModels[model] then
			local isOpen = model:GetAttribute("Open")

			if isOpen == false then
				local part = GetInteractablePart(model)

				if part then
					table.insert(targets, {
						model = model,
						part = part,
					})
				else
					Debug(model.Name .. " ignoré : pas de Part Interactable")
				end
			end
		end
	end

	table.sort(targets, function(a, b)
		local root = GetRoot()
		return (root.Position - a.part.Position).Magnitude < (root.Position - b.part.Position).Magnitude
	end)

	return targets
end

--==================================================
-- DÉPLACEMENT
--==================================================

local function GetUnderCFrame(part)
	local position = part.Position - Vector3.new(0, underOffset, 0)
	return CFrame.lookAt(position, part.Position)
end

local function MoveToCFrame(targetCFrame)
	local root = GetRoot()
	local distance = (root.Position - targetCFrame.Position).Magnitude
	local duration = math.clamp(distance / moveSpeed, 0.03, 0.8)

	local tween = TweenService:Create(
		root,
		TweenInfo.new(duration, Enum.EasingStyle.Linear),
		{ CFrame = targetCFrame }
	)

	tween:Play()
	tween.Completed:Wait()

	root.CFrame = targetCFrame
	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero
end

--==================================================
-- INTERACTION PROPRE
--==================================================

local function GetActionName(model)
	local nameType = model.Name:match("^(%a+)_")

	if nameType == "OilBucket" then
		return "OpenOilBucket"
	elseif nameType == "Crate" then
		return "OpenCrate"
	elseif nameType == "Cabinet" then
		return "OpenCabinet"
	elseif nameType == "SoilMound" then
		return "OpenSoilMound"
	elseif nameType == "Fridge" then
		return "OpenFridge"
	end

	return nil
end

local function ClickContainer(model)
	if not model then
		return false
	end

	if not model.Parent then
		return false
	end

	local actionName = GetActionName(model)

	if not actionName then
		Debug(model.Name .. " : action inconnue")
		return false
	end

	local success, err = pcall(function()
		remoteEvent:FireServer(actionName, model)
	end)

	if not success then
		Debug(model.Name .. " : erreur Remote_Event")
		warn(err)
		return false
	end

	Debug(model.Name .. " : demande envoyée")
	return true
end

local function WaitUntilOpen(model)
	local startTime = os.clock()

	while autoFarmEnabled and not destroyed and os.clock() - startTime < waitOpenTimeout do
		if model:GetAttribute("Open") == true then
			Debug(model.Name .. " : Open = true")
			return true
		end

		task.wait(0.03)
	end

	Debug(model.Name .. " : Open toujours false")
	return false
end

local function TryOpenContainer(model)
	if not model then
		return false
	end

	Debug(model.Name .. " : ouverture demandée")

	for i = 1, openSpamCount do
		if destroyed then
			return false
		end

		if not autoFarmEnabled then
			return false
		end

		if model:GetAttribute("Open") == true then
			Debug(model.Name .. " : déjà ouvert")
			return true
		end

		Debug(model.Name .. " : tentative " .. i .. "/" .. openSpamCount)

		ClickContainer(model)

		task.wait(openSpamDelay)
	end

	return WaitUntilOpen(model)
end

--==================================================
-- ÉTAPE 1 : OUVRIR UN CONTENANT
--==================================================

local function Step1_OpenOneContainer(target)
	if not target then return false end
	if not target.model then return false end
	if not target.part then return false end
	if not target.model.Parent then return false end
	if not target.part.Parent then return false end

	local model = target.model
	local part = target.part

	Debug("Déplacement vers " .. model.Name)

	MoveToCFrame(GetUnderCFrame(part))

	currentTargetModel = model
	currentTargetPart = part

	FreezePlayer()

	local opened = TryOpenContainer(model)

	currentTargetModel = nil
	currentTargetPart = nil

	UnfreezePlayer()

	if opened then
		Debug(model.Name .. " : ouvert")
		return true
	end

	failedAttempts[model] = (failedAttempts[model] or 0) + 1

	Debug(model.Name .. " : échec " .. failedAttempts[model] .. "/" .. maxOpenTriesPerContainer)

	if failedAttempts[model] >= maxOpenTriesPerContainer then
		skippedModels[model] = true
		Debug(model.Name .. " : skip")
	end

	return false
end

local function Step1_OpenAllContainers()
	Debug("Étape 1 : ouverture des contenants")

	while autoFarmEnabled and not destroyed do
		local targets = GetTargets()

		if #targets == 0 then
			Debug("Étape 1 terminée")
			return true
		end

		local target = targets[1]

		if target and target.model then
			Step1_OpenOneContainer(target)
		else
			task.wait(0.1)
		end

		task.wait(0.1)
	end

	return false
end

