local function Debug(message)
	print("[AUTO FARM] " .. message)

	table.insert(lastDebugLines, 1, message)

	while #lastDebugLines > 8 do
		table.remove(lastDebugLines)
	end

	debugLabel.Text = "Debug :\n" .. table.concat(lastDebugLines, "\n")
end

