-- Fonction pour afficher dans la console de l'interface
local function AddDebugMsg(msg)
    local current = debugText.Text
    local lines = {}
    for line in current:gmatch("[^\n]+") do
        table.insert(lines, line)
    end
    table.insert(lines, os.date("%H:%M:%S") .. " > " .. msg)
    if #lines > 15 then table.remove(lines, 1) end
    debugText.Text = table.concat(lines, "\n")
    debugScroll.CanvasSize = UDim2.new(0, 0, 0, debugText.TextBounds.Y + 10)
    print("[AUTOFARM] " .. msg)
end

--==================================================
-- CAPTURE DES REMOTES (mode apprentissage)
--==================================================
local function EnableCaptureMode(enable)
    recordingMode = enable
    if enable then
        -- Intercepter FireServer
        remoteEvent.FireServer = function(self, ...)
            local args = {...}
            -- Identifier le type de conteneur à partir du second argument (table contenant le modèle)
            local model = args[2] and args[2][1]
            local containerType = nil
            if model and model:IsA("Model") then
                containerType = model.Name:match("^(%a+)_")
            end
            if containerType then
                capturedArgs[containerType] = args  -- sauvegarde exacte des arguments
                AddDebugMsg("📥 CAPTURÉ " .. containerType .. " : " .. tostring(#args) .. " args")
            else
                AddDebugMsg("⚠️ Capture reçue mais type inconnu")
            end
            -- On laisse passer l'appel original
            return originalFireServer(self, ...)
        end
        toggleRecordBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        toggleRecordBtn.Text = "🔴 MODE CAPTURE : ON"
        AddDebugMsg("Mode CAPTURE activé. Clique sur un conteneur pour enregistrer son RemoteEvent.")
    else
        -- Restaurer le FireServer original
        remoteEvent.FireServer = originalFireServer
        toggleRecordBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 90)
        toggleRecordBtn.Text = "🔴 MODE CAPTURE : OFF"
        AddDebugMsg("Mode CAPTURE désactivé.")
    end
end

toggleRecordBtn.MouseButton1Click:Connect(function()
    EnableCaptureMode(not recordingMode)
end)

--==================================================
-- FONCTIONS JOUEUR / DÉPLACEMENT
--==================================================
local function GetCharacter()
    return player.Character or player.CharacterAdded:Wait()
end

local function GetHumanoid()
    return GetCharacter():WaitForChild("Humanoid")
end

local function GetRoot()
    return GetCharacter():WaitForChild("HumanoidRootPart")
end

local function SaveMovement()
    local hum = GetHumanoid()
    if oldWalkSpeed == nil then
        oldWalkSpeed = hum.WalkSpeed
        oldJumpPower = hum.JumpPower
        oldJumpHeight = hum.JumpHeight
        oldAutoRotate = hum.AutoRotate
    end
end

local function FreezePlayer()
    local hum = GetHumanoid()
    local root = GetRoot()
    SaveMovement()
    hum.WalkSpeed = 0
    hum.JumpPower = 0
    hum.JumpHeight = 0
    hum.AutoRotate = false
    root.AssemblyLinearVelocity = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero
end

local function UnfreezePlayer()
    local hum = GetHumanoid()
    if oldWalkSpeed then
        hum.WalkSpeed = oldWalkSpeed
        hum.JumpPower = oldJumpPower
        hum.JumpHeight = oldJumpHeight
        hum.AutoRotate = oldAutoRotate
    end
    oldWalkSpeed = nil
    oldJumpPower = nil
    oldJumpHeight = nil
    oldAutoRotate = nil
end

local function GetUnderCFrame(part)
    return CFrame.lookAt(part.Position - Vector3.new(0, UNDER_OFFSET, 0), part.Position)
end

local function MoveToCFrame(targetCFrame)
    local root = GetRoot()
    local dist = (root.Position - targetCFrame.Position).Magnitude
    local duration = math.clamp(dist / MOVE_SPEED, 0.03, 0.8)
    local tween = TweenService:Create(root, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
    tween:Play()
    tween.Completed:Wait()
    root.CFrame = targetCFrame
    root.AssemblyLinearVelocity = Vector3.zero
end

--==================================================
-- INTERACTION (utilise les captures ou fallback)
--==================================================
local function PressE()
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
end

local function ClickOnPart(part)
    local cam = workspace.CurrentCamera
    local pos, onScreen = cam:WorldToScreenPoint(part.Position)
    if not onScreen then return false end
    VirtualInputManager:SendMouseMoveEvent(pos.X, pos.Y, 0, game)
    task.wait()
    VirtualInputManager:SendMouseButtonEvent(true, Enum.UserInputType.MouseButton1, 0, false, game)
    task.wait(0.05)
    VirtualInputManager:SendMouseButtonEvent(false, Enum.UserInputType.MouseButton1, 0, false, game)
    return true
end

local function InteractWithRemote(model, part)
    local typeName = model.Name:match("^(%a+)_")
    local args = capturedArgs[typeName]
    if args then
        -- Rejouer exactement les arguments capturés
        pcall(function()
            remoteEvent:FireServer(unpack(args))
        end)
        AddDebugMsg("📡 Remote utilisé pour " .. typeName)
        return true
    else
        AddDebugMsg("⚠️ Aucune capture pour " .. (typeName or "?"))
        -- Fallback : simulation E + clic
        if ClickOnPart(part) then
            AddDebugMsg("🖱️ Clic souris simulé")
        else
            PressE()
            AddDebugMsg("⌨️ Touche E simulée")
        end
        return false
    end
end

local function WaitForOpen(model)
    local start = os.clock()
    while os.clock() - start < WAIT_TIMEOUT do
        if model:GetAttribute("Open") == true then
            return true
        end
        task.wait(0.03)
    end
    return false
end

local function TryOpen(model, part)
    AddDebugMsg("Tentative ouverture " .. model.Name)
    for i = 1, SPAM_COUNT do
        if model:GetAttribute("Open") == true then return true end
        InteractWithRemote(model, part)
        task.wait(SPAM_DELAY)
    end
    return WaitForOpen(model)
end

--==================================================
-- RECHERCHE DES CONTENEURS
--==================================================
local function GetInteractiveFolder()
    local gs = workspace:FindFirstChild("GameSystem")
    if not gs then return nil end
    return gs:FindFirstChild("InteractiveItem")
end

local function IsValidContainer(model)
    if not model:IsA("Model") then return false end
    local typeName = model.Name:match("^(%a+)_")
    if not typeName then return false end
    for _, t in ipairs(CONTAINER_TYPES) do
        if typeName == t then return true end
    end
    return false
end

local function GetTargets()
    local folder = GetInteractiveFolder()
    if not folder then return {} end
    local targets = {}
    for _, model in ipairs(folder:GetChildren()) do
        if IsValidContainer(model) and model:GetAttribute("Open") == false then
            local part = model:FindFirstChild("Interactable", true)
            if part and part:IsA("BasePart") then
                table.insert(targets, {model = model, part = part})
            end
        end
    end
    local root = GetRoot()
    table.sort(targets, function(a,b)
        return (root.Position - a.part.Position).Magnitude < (root.Position - b.part.Position).Magnitude
    end)
    return targets
end

--==================================================
-- BOUCLE AUTO FARM
--==================================================
local function StartAutoFarm()
    if farming then return end
    if autoFarmEnabled == false then
        AddDebugMsg("AutoFarm désactivé, démarrer avec le bouton ON")
        return
    end
    farming = true
    AddDebugMsg("=== AUTO FARM LANCÉ ===")

    local targets = GetTargets()
    if #targets == 0 then
        AddDebugMsg("Aucun conteneur fermé trouvé")
        farming = false
        return
    end

    for _, target in ipairs(targets) do
        if not autoFarmEnabled then break end
        local model, part = target.model, target.part
        AddDebugMsg("--- Cible : " .. model.Name .. " ---")
        MoveToCFrame(GetUnderCFrame(part))
        FreezePlayer()
        currentTarget = part
        currentPart = part

        local success = false
        for attempt = 1, MAX_ATTEMPTS do
            if not autoFarmEnabled then break end
            if model:GetAttribute("Open") == true then
                success = true
                break
            end
            AddDebugMsg("Essai " .. attempt .. "/" .. MAX_ATTEMPTS)
            if TryOpen(model, part) then
                success = true
                break
            end
            task.wait(0.5)
        end

        currentTarget = nil
        currentPart = nil
        UnfreezePlayer()
        if success then
            AddDebugMsg("✅ " .. model.Name .. " ouvert")
        else
            AddDebugMsg("❌ " .. model.Name .. " échec")
        end
        task.wait(0.3)
    end

    AddDebugMsg("=== AUTO FARM TERMINÉ ===")
    farming = false
    if camera.CameraType == Enum.CameraType.Scriptable then
        camera.CameraType = oldCameraType
    end
end

startAutoBtn.MouseButton1Click:Connect(function()
    if recordingMode then
        AddDebugMsg("Désactive d'abord le mode CAPTURE")
        return
    end
    autoFarmEnabled = true
    AddDebugMsg("AutoFarm activé")
    task.spawn(StartAutoFarm)
end)

stopAutoBtn.MouseButton1Click:Connect(function()
    autoFarmEnabled = false
    farming = false
    currentTarget = nil
    UnfreezePlayer()
    if camera.CameraType == Enum.CameraType.Scriptable then
        camera.CameraType = oldCameraType
    end
    AddDebugMsg("AutoFarm désactivé")
end)

