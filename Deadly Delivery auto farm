--==================================================

local function GoToFinalPosition()
	Debug("Téléport final")

	currentTargetModel = nil
	currentTargetPart = nil

	UnfreezePlayer()
	camera.CameraType = oldCameraType

	ForceTeleportTo(finalPosition, 1)

	Debug("Téléport final terminé")
end

local function StartFarm()
	if farming then return end

	farming = true

	Debug("Auto farm lancé")

	FindRemoteEvent()

	local step1Done = Step1_OpenAllContainers()

	if step1Done and autoFarmEnabled and not destroyed then
		local step2Done = Step2_CollectAndDrop()

		if step2Done and autoFarmEnabled and not destroyed then
			local step3Done = Step3_UpgradeItems()

			if step3Done and autoFarmEnabled and not destroyed then
				GoToFinalPosition()
			end
		end
	end

	while autoFarmEnabled and not destroyed do
		task.wait(0.5)
	end

	currentTargetModel = nil
	currentTargetPart = nil

	UnfreezePlayer()
	camera.CameraType = oldCameraType

	farming = false

	Debug("Auto farm arrêté")
end

--==================================================
-- ON / OFF
--==================================================

local function SetAutoFarm(state)
	autoFarmEnabled = state

	if autoFarmEnabled then
		toggleButton.Text = "Auto Farm : ON"
		toggleButton.BackgroundColor3 = Color3.fromRGB(40, 150, 70)

		Debug("ON")
		task.spawn(StartFarm)
	else
		toggleButton.Text = "Auto Farm : OFF"
		toggleButton.BackgroundColor3 = Color3.fromRGB(160, 40, 40)

		Debug("OFF")

		currentTargetModel = nil
		currentTargetPart = nil

		UnfreezePlayer()
		camera.CameraType = oldCameraType
	end
end

local function DestroyAll()
	destroyed = true
	autoFarmEnabled = false

	currentTargetModel = nil
	currentTargetPart = nil

	UnfreezePlayer()
	camera.CameraType = oldCameraType

	ContextActionService:UnbindAction("AutoFarmInteract")

	for _, connection in ipairs(connections) do
		if connection then
			connection:Disconnect()
		end
	end

	if screenGui then
		screenGui:Destroy()
	end

	script:Destroy()
end

--==================================================
-- CAMÉRA + NOCLIP
--==================================================

table.insert(connections, RunService.RenderStepped:Connect(function()
	if destroyed then return end

	if autoFarmEnabled then
		DisableCollisions()
	end

	if currentTargetPart and currentTargetPart.Parent then
		local root = GetRoot()
		local lockCFrame = GetUnderCFrame(currentTargetPart)

		root.CFrame = lockCFrame
		root.AssemblyLinearVelocity = Vector3.zero
		root.AssemblyAngularVelocity = Vector3.zero

		camera.CameraType = Enum.CameraType.Scriptable
		camera.CFrame = CFrame.lookAt(
			root.Position + Vector3.new(0, 1.5, 0),
			currentTargetPart.Position + Vector3.new(0, 1, 0)
		)
	end
end))

