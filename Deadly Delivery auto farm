local VirtualInputManager = game:GetService("VirtualInputManager")
local Players = game:GetService("Players")
local player = Players.LocalPlayer
local character = player.Character
local humanoidRootPart = character and character:FindFirstChild("HumanoidRootPart")

local function pressE()
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
end

local function teleportAndFarm(targetPart)
    if not targetPart or not targetPart.Parent then return end
    local targetPos = targetPart.Position - Vector3.new(0, 2.5, 0)
    humanoidRootPart.CFrame = CFrame.new(targetPos)
    task.wait(0.5)
    for i = 1, 20 do
        pressE()
        task.wait(0.1)
    end
end

local targetPart = workspace:WaitForChild("GameSystem"):WaitForChild("InteractiveItem"):WaitForChild("OilBucket_XX"):FindFirstChild("Interactable", true)
teleportAndFarm(targetPart)
