--==================================================
-- AUTO FARM ULTRA SIMPLE (sans UI, juste print)
-- Simulation clic utilisateur (touche E + clic souris)
-- 5 essais max par conteneur
--==================================================

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local VirtualInputManager = game:GetService("VirtualInputManager")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

-- Configuration
local MOVE_SPEED = 700
local UNDER_OFFSET = 2.2
local MAX_ATTEMPTS = 5          -- 5 essais max par conteneur
local SPAM_COUNT = 8
local SPAM_DELAY = 0.05
local WAIT_TIMEOUT = 1.2

-- Types de conteneurs
local CONTAINER_TYPES = {
    "Cabinet", "Crate", "OilBucket", "SoilMound", "Fridge"
}

-- État
local farming = false
local currentTarget = nil
local oldWalkSpeed = nil
local oldJumpPower = nil
local oldJumpHeight = nil
local oldAutoRotate = nil
local oldCameraType = camera.CameraType

--==================================================
-- FONCTIONS UTILITAIRES
--==================================================
local function GetCharacter()
    return player.Character or player.CharacterAdded:Wait()
end

local function GetHumanoid()
    return GetCharacter():WaitForChild("Humanoid")
end

local function GetRoot()
    return GetCharacter():WaitForChild("HumanoidRootPart")
end

local function SaveMovement()
    local hum = GetHumanoid()
    if oldWalkSpeed == nil then
        oldWalkSpeed = hum.WalkSpeed
        oldJumpPower = hum.JumpPower
        oldJumpHeight = hum.JumpHeight
        oldAutoRotate = hum.AutoRotate
    end
end

local function FreezePlayer()
    local hum = GetHumanoid()
    local root = GetRoot()
    SaveMovement()
    hum.WalkSpeed = 0
    hum.JumpPower = 0
    hum.JumpHeight = 0
    hum.AutoRotate = false
    root.AssemblyLinearVelocity = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero
end

local function UnfreezePlayer()
    local hum = GetHumanoid()
    if oldWalkSpeed then
        hum.WalkSpeed = oldWalkSpeed
        hum.JumpPower = oldJumpPower
        hum.JumpHeight = oldJumpHeight
        hum.AutoRotate = oldAutoRotate
    end
    oldWalkSpeed = nil
    oldJumpPower = nil
    oldJumpHeight = nil
    oldAutoRotate = nil
end

--==================================================
-- RECHERCHE DES CONTENEURS
--==================================================
local function GetInteractiveFolder()
    local gs = workspace:FindFirstChild("GameSystem")
    if not gs then return nil end
    return gs:FindFirstChild("InteractiveItem")
end

local function IsValidContainer(model)
    if not model:IsA("Model") then return false end
    local typeName = model.Name:match("^(%a+)_")
    if not typeName then return false end
    for _, t in ipairs(CONTAINER_TYPES) do
        if typeName == t then return true end
    end
    return false
end

local function GetTargets()
    local folder = GetInteractiveFolder()
    if not folder then return {} end
    local targets = {}
    for _, model in ipairs(folder:GetChildren()) do
        if IsValidContainer(model) and model:GetAttribute("Open") == false then
            local part = model:FindFirstChild("Interactable", true)
            if part and part:IsA("BasePart") then
                table.insert(targets, {model = model, part = part})
            end
        end
    end
    -- Tri par distance
    local root = GetRoot()
    table.sort(targets, function(a,b)
        return (root.Position - a.part.Position).Magnitude < (root.Position - b.part.Position).Magnitude
    end)
    return targets
end

--==================================================
-- DÉPLACEMENT
--==================================================
local function GetUnderCFrame(part)
    return CFrame.lookAt(part.Position - Vector3.new(0, UNDER_OFFSET, 0), part.Position)
end

local function MoveToCFrame(targetCFrame)
    local root = GetRoot()
    local dist = (root.Position - targetCFrame.Position).Magnitude
    local duration = math.clamp(dist / MOVE_SPEED, 0.03, 0.8)
    local tween = TweenService:Create(root, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
    tween:Play()
    tween.Completed:Wait()
    root.CFrame = targetCFrame
    root.AssemblyLinearVelocity = Vector3.zero
end

--==================================================
-- SIMULATION DE CLIC UTILISATEUR (touche E + souris)
--==================================================
local function PressE()
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
end

local function ClickOnPart(part)
    local cam = workspace.CurrentCamera
    local pos, onScreen = cam:WorldToScreenPoint(part.Position)
    if not onScreen then return false end
    VirtualInputManager:SendMouseMoveEvent(pos.X, pos.Y, 0, game)
    task.wait()
    VirtualInputManager:SendMouseButtonEvent(true, Enum.UserInputType.MouseButton1, 0, false, game)
    task.wait(0.05)
    VirtualInputManager:SendMouseButtonEvent(false, Enum.UserInputType.MouseButton1, 0, false, game)
    return true
end

local function InteractLikePlayer(part)
    -- D'abord essayer le clic souris (pour ClickDetector)
    if ClickOnPart(part) then
        print("[OK] Clic souris simulé")
        return true
    end
    -- Sinon, appuyer sur E (pour ProximityPrompt)
    PressE()
    print("[OK] Touche E simulée")
    return true
end

--==================================================
-- OUVERTURE D'UN CONTENEUR AVEC SPAM
--==================================================
local function WaitForOpen(model)
    local start = os.clock()
    while os.clock() - start < WAIT_TIMEOUT do
        if model:GetAttribute("Open") == true then
            return true
        end
        task.wait(0.03)
    end
    return false
end

local function TryOpen(model, part)
    print("[*] Ouverture de " .. model.Name)
    for i = 1, SPAM_COUNT do
        if model:GetAttribute("Open") == true then
            print("[+] " .. model.Name .. " déjà ouvert")
            return true
        end
        InteractLikePlayer(part)
        task.wait(SPAM_DELAY)
    end
    return WaitForOpen(model)
end

--==================================================
-- FARM PRINCIPAL
--==================================================
local function FarmContainers()
    if farming then return end
    farming = true
    print("=== AUTO FARM DÉMARRÉ (5 essais max par conteneur) ===")

    local targets = GetTargets()
    if #targets == 0 then
        print("[!] Aucun conteneur fermé trouvé")
        farming = false
        return
    end

    for _, target in ipairs(targets) do
        if not farming then break end
        local model, part = target.model, target.part

        print("--- Cible : " .. model.Name .. " ---")
        -- Déplacement
        MoveToCFrame(GetUnderCFrame(part))
        -- Freeze et interaction
        FreezePlayer()
        currentTarget = part

        local success = false
        for attempt = 1, MAX_ATTEMPTS do
            if model:GetAttribute("Open") == true then
                success = true
                break
            end
            print("[Tentative " .. attempt .. "/" .. MAX_ATTEMPTS .. "]")
            if TryOpen(model, part) then
                success = true
                break
            end
            task.wait(0.5) -- petit délai entre les tentatives
        end

        currentTarget = nil
        UnfreezePlayer()

        if success then
            print("[SUCCÈS] " .. model.Name .. " ouvert")
        else
            print("[ÉCHEC] " .. model.Name .. " non ouvert après " .. MAX_ATTEMPTS .. " essais")
        end
        task.wait(0.3)
    end

    print("=== AUTO FARM TERMINÉ ===")
    farming = false
    if camera.CameraType == Enum.CameraType.Scriptable then
        camera.CameraType = oldCameraType
    end
end

--==================================================
-- LANCEMENT AUTOMATIQUE
--==================================================
-- On récupère le type de caméra original
oldCameraType = camera.CameraType

-- Boucle de maintien de la caméra sur la cible (optionnel)
RunService.RenderStepped:Connect(function()
    if currentTarget and currentTarget.Parent then
        local root = GetRoot()
        local lockCFrame = GetUnderCFrame(currentTarget)
        root.CFrame = lockCFrame
        root.AssemblyLinearVelocity = Vector3.zero
        camera.CameraType = Enum.CameraType.Scriptable
        camera.CFrame = CFrame.lookAt(root.Position + Vector3.new(0, 1.5, 0), currentTarget.Position + Vector3.new(0, 1, 0))
    else
        if camera.CameraType == Enum.CameraType.Scriptable then
            camera.CameraType = oldCameraType
        end
    end
end)

-- Démarrer le farm
task.spawn(FarmContainers)
