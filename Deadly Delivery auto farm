--==================================================
-- JOUEUR
--==================================================
local function GetCharacter()
	return player.Character or player.CharacterAdded:Wait()
end

local function GetHumanoid()
	return GetCharacter():WaitForChild("Humanoid")
end

local function GetRoot()
	return GetCharacter():WaitForChild("HumanoidRootPart")
end

local function SaveMovement()
	local hum = GetHumanoid()
	if oldWalkSpeed == nil then
		oldWalkSpeed = hum.WalkSpeed
		oldJumpPower = hum.JumpPower
		oldJumpHeight = hum.JumpHeight
		oldAutoRotate = hum.AutoRotate
	end
end

local function FreezePlayer()
	local hum = GetHumanoid()
	local root = GetRoot()
	SaveMovement()
	hum.WalkSpeed = 0
	hum.JumpPower = 0
	hum.JumpHeight = 0
	hum.AutoRotate = false
	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero
end

local function UnfreezePlayer()
	local hum = GetHumanoid()
	if oldWalkSpeed then
		hum.WalkSpeed = oldWalkSpeed
		hum.JumpPower = oldJumpPower
		hum.JumpHeight = oldJumpHeight
		hum.AutoRotate = oldAutoRotate
	end
	oldWalkSpeed = nil
	oldJumpPower = nil
	oldJumpHeight = nil
	oldAutoRotate = nil
end

--==================================================
-- RECHERCHE DES CONTENEURS
--==================================================
local function GetFolder()
	local gameSystem = workspace:FindFirstChild("GameSystem")
	if not gameSystem then Debug("GameSystem introuvable"); return nil end
	return gameSystem:FindFirstChild("InteractiveItem")
end

local function IsValidModel(model)
	if not model:IsA("Model") then return false end
	local nameType = model.Name:match("^(%a+)_")
	if not nameType then return false end
	for _, valid in ipairs(contenants) do
		if nameType == valid then return true end
	end
	return false
end

local function GetInteractablePart(model)
	return model:FindFirstChild("Interactable", true)
end

local function GetTargets()
	local folder = GetFolder()
	local targets = {}
	if not folder then return targets end
	for _, model in ipairs(folder:GetChildren()) do
		if IsValidModel(model) and not skippedModels[model] then
			if model:GetAttribute("Open") == false then
				local part = GetInteractablePart(model)
				if part and part:IsA("BasePart") then
					table.insert(targets, { model = model, part = part })
				end
			end
		end
	end
	table.sort(targets, function(a,b)
		local root = GetRoot()
		return (root.Position - a.part.Position).Magnitude < (root.Position - b.part.Position).Magnitude
	end)
	return targets
end

--==================================================
-- DÉPLACEMENT
--==================================================
local function GetUnderCFrame(part)
	return CFrame.lookAt(part.Position - Vector3.new(0, underOffset, 0), part.Position)
end

local function MoveToCFrame(targetCFrame)
	local root = GetRoot()
	local dist = (root.Position - targetCFrame.Position).Magnitude
	local duration = math.clamp(dist / moveSpeed, 0.03, 0.8)
	local tween = TweenService:Create(root, TweenInfo.new(duration, Enum.EasingStyle.Linear), { CFrame = targetCFrame })
	tween:Play()
	tween.Completed:Wait()
	root.CFrame = targetCFrame
	root.AssemblyLinearVelocity = Vector3.zero
end

--==================================================
-- INTERACTION : TOUCHE E / PROMPT MOBILE
--==================================================
local function TriggerInteraction(part, model)
	-- 1) Chercher un ProximityPrompt (touche E)
	local prompt = part:FindFirstChild("ProximityPrompt") or model:FindFirstChild("ProximityPrompt")
	if prompt and prompt:IsA("ProximityPrompt") then
		local character = GetCharacter()
		prompt:Prompt(character)
		Debug(model.Name .. " : Prompt déclenché (touche E / mobile)")
		return true
	end
	-- 2) Fallback : ClickDetector
	local click = part:FindFirstChild("ClickDetector") or model:FindFirstChild("ClickDetector")
	if click and click:IsA("ClickDetector") then
		click:Click()
		Debug(model.Name .. " : ClickDetector déclenché")
		return true
	end
	Debug(model.Name .. " : ni Prompt ni ClickDetector trouvé")
	return false
end

local function WaitUntilOpen(model)
	local start = os.clock()
	while autoFarmEnabled and not destroyed and os.clock() - start < waitOpenTimeout do
		if model:GetAttribute("Open") == true then
			return true
		end
		task.wait(0.03)
	end
	return false
end

local function TryOpenContainer(model, part)
	Debug(model.Name .. " : tentative d'ouverture")
	for i = 1, openSpamCount do
		if not autoFarmEnabled or destroyed then return false end
		if model:GetAttribute("Open") == true then return true end
		TriggerInteraction(part, model)
		task.wait(openSpamDelay)
	end
	return WaitUntilOpen(model)
end

--==================================================
-- ÉTAPE 1 : OUVRIR TOUS LES CONTENEURS
--==================================================
local function Step1_OpenOneContainer(target)
	if not target or not target.model or not target.part then return false end
	local model, part = target.model, target.part

	Debug("Déplacement vers " .. model.Name)
	MoveToCFrame(GetUnderCFrame(part))

	currentTargetModel = model
	currentTargetPart = part
	FreezePlayer()

	local opened = TryOpenContainer(model, part)

	currentTargetModel = nil
	currentTargetPart = nil
	UnfreezePlayer()

	if opened then
		Debug(model.Name .. " : ouvert avec succès")
		return true
	end

	failedAttempts[model] = (failedAttempts[model] or 0) + 1
	if failedAttempts[model] >= maxOpenTriesPerContainer then
		skippedModels[model] = true
		Debug(model.Name .. " : skip définitif")
	end
	return false
end

local function Step1_OpenAllContainers()
	Debug("Étape 1 : ouverture de tous les contenants")
	while autoFarmEnabled and not destroyed do
		local targets = GetTargets()
		if #targets == 0 then
			Debug("Étape 1 terminée")
			return true
		end
		Step1_OpenOneContainer(targets[1])
		task.wait(0.1)
	end
	return false
end

