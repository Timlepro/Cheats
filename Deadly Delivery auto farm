local debugLines = {}

local function Debug(message)
	print("[AUTO FARM] " .. message)

	table.insert(debugLines, 1, message)

	while #debugLines > 8 do
		table.remove(debugLines)
	end

	debugLabel.Text = "Debug :\n" .. table.concat(debugLines, "\n")
end

--==================================================
-- JOUEUR
--==================================================

local function GetCharacter()
	return player.Character or player.CharacterAdded:Wait()
end

local function GetHumanoid()
	return GetCharacter():WaitForChild("Humanoid")
end

local function GetRoot()
	return GetCharacter():WaitForChild("HumanoidRootPart")
end

local function SaveMovement()
	local humanoid = GetHumanoid()

	if oldWalkSpeed == nil then
		oldWalkSpeed = humanoid.WalkSpeed
		oldJumpPower = humanoid.JumpPower
		oldJumpHeight = humanoid.JumpHeight
		oldAutoRotate = humanoid.AutoRotate
	end
end

local function FreezePlayer()
	local humanoid = GetHumanoid()
	local root = GetRoot()

	SaveMovement()

	humanoid.WalkSpeed = 0
	humanoid.JumpPower = 0
	humanoid.JumpHeight = 0
	humanoid.AutoRotate = false

	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero
end

local function UnfreezePlayer()
	local humanoid = GetHumanoid()

	if oldWalkSpeed ~= nil then
		humanoid.WalkSpeed = oldWalkSpeed
		humanoid.JumpPower = oldJumpPower
		humanoid.JumpHeight = oldJumpHeight
		humanoid.AutoRotate = oldAutoRotate
	end

	oldWalkSpeed = nil
	oldJumpPower = nil
	oldJumpHeight = nil
	oldAutoRotate = nil
end

local function DisableCollisions()
	local character = GetCharacter()

	for _, object in ipairs(character:GetDescendants()) do
		if object:IsA("BasePart") then
			object.CanCollide = false
		end
	end
end

