-- DEBUG INTERACTION FINDER
--==================================================

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local contenants = {
	"Cabinet",
	"Crate",
	"OilBucket",
	"SoilMound",
	"Fridge"
}

local function Debug(message)
	print("[FINDER] " .. tostring(message))
end

local function IsNameInList(name)
	for _, validName in ipairs(contenants) do
		if name == validName then
			return true
		end
	end

	return false
end

local function IsValidModel(model)
	if not model:IsA("Model") then return false end

	local nameType, number = model.Name:match("^(%a+)_([0-9]+)$")

	if not nameType then return false end
	if not number then return false end

	return IsNameInList(nameType)
end

local function GetFolder()
	local gameSystem = workspace:FindFirstChild("GameSystem")
	if not gameSystem then return nil end

	return gameSystem:FindFirstChild("InteractiveItem")
end

local function PrintObjectInfo(object, indent)
	indent = indent or ""

	Debug(indent .. object.ClassName .. " | " .. object.Name)

	for _, child in ipairs(object:GetChildren()) do
		if child:IsA("RemoteEvent") then
			Debug(indent .. "  REMOTE EVENT -> " .. child:GetFullName())
		elseif child:IsA("RemoteFunction") then
			Debug(indent .. "  REMOTE FUNCTION -> " .. child:GetFullName())
		elseif child:IsA("BindableEvent") then
			Debug(indent .. "  BINDABLE EVENT -> " .. child:GetFullName())
		elseif child:IsA("BindableFunction") then
			Debug(indent .. "  BINDABLE FUNCTION -> " .. child:GetFullName())
		elseif child:IsA("LocalScript") then
			Debug(indent .. "  LOCAL SCRIPT -> " .. child:GetFullName())
		elseif child:IsA("Script") then
			Debug(indent .. "  SERVER SCRIPT -> " .. child:GetFullName())
		elseif child:IsA("ModuleScript") then
			Debug(indent .. "  MODULE SCRIPT -> " .. child:GetFullName())
		elseif child:IsA("ClickDetector") then
			Debug(indent .. "  CLICK DETECTOR -> " .. child:GetFullName())
		elseif child:IsA("ProximityPrompt") then
			Debug(indent .. "  PROXIMITY PROMPT -> " .. child:GetFullName())
		end
	end
end

local function ScanReplicatedStorage()
	Debug("========== SCAN REPLICATED STORAGE ==========")

	for _, object in ipairs(ReplicatedStorage:GetDescendants()) do
		if object:IsA("RemoteEvent") then
			Debug("RemoteEvent : " .. object:GetFullName())
		elseif object:IsA("RemoteFunction") then
			Debug("RemoteFunction : " .. object:GetFullName())
		elseif object:IsA("ModuleScript") then
			Debug("ModuleScript : " .. object:GetFullName())
		end
	end
end

local function ScanPlayerGui()
	Debug("========== SCAN PLAYER GUI ==========")

	for _, object in ipairs(playerGui:GetDescendants()) do
		if object.Name:lower():find("interact") then
			Debug("Interact GUI trouvé : " .. object.ClassName .. " | " .. object:GetFullName())
		end

		if object.Name:lower():find("touch") then
			Debug("Touch GUI trouvé : " .. object.ClassName .. " | " .. object:GetFullName())
		end

		if object.Name:lower():find("button") then
			Debug("Button GUI trouvé : " .. object.ClassName .. " | " .. object:GetFullName())
		end
	end
end

local function ScanContainers()
	local folder = GetFolder()

	if not folder then
		Debug("Folder InteractiveItem introuvable")
		return
	end

	Debug("========== SCAN CONTENANTS ==========")

	for _, model in ipairs(folder:GetChildren()) do
		if IsValidModel(model) then
			Debug("Contenant : " .. model.Name)
			Debug("Open attribute : " .. tostring(model:GetAttribute("Open")))

			PrintObjectInfo(model, "  ")

			model:GetAttributeChangedSignal("Open"):Connect(function()
				Debug(model.Name .. " Open changé -> " .. tostring(model:GetAttribute("Open")))
			end)
		end
	end
end

ScanReplicatedStorage()
ScanPlayerGui()
ScanContainers()

Debug("Maintenant ouvre un contenant manuellement avec E et regarde les prints.")
