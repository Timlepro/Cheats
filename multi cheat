-- Fonction pour basculer le mode réduit
local function ToggleMinimize()
    IsMinimized = not IsMinimized
    
    if IsMinimized then
        -- Sauvegarder la taille actuelle
        FullSize.Width = MainFrame.Size.X.Offset
        FullSize.Height = MainFrame.Size.Y.Offset
        
        -- Réduire à la barre de titre
        local targetWidth = math.min(200, MainFrame.Size.X.Offset)
        TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
            Size = UDim2.new(0, targetWidth, 0, MinimizedSize)
        }):Play()
        
        ContentContainer.Visible = false
        ToggleButton.ImageColor3 = Color3.fromRGB(50, 200, 50)
        
        -- Mettre à jour le titre
        Title.Text = "📁 Scripts ▼"
    else
        -- Restaurer la taille
        TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
            Size = UDim2.new(0, FullSize.Width, 0, FullSize.Height)
        }):Play()
        
        wait(0.3)
        ContentContainer.Visible = true
        ToggleButton.ImageColor3 = Color3.fromRGB(200, 200, 50)
        
        -- Mettre à jour le titre
        Title.Text = "📁 Script Executor"
    end
end

-- Fonction de déplacement
local function StartDrag(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        Dragging = true
        DragStart = input.Position
        StartPos = MainFrame.Position
    end
end

local function UpdateDrag(input)
    if Dragging then
        local delta = input.Position - DragStart
        MainFrame.Position = UDim2.new(
            StartPos.X.Scale,
            StartPos.X.Offset + delta.X,
            StartPos.Y.Scale,
            StartPos.Y.Offset + delta.Y
        )
    end
end

local function EndDrag()
    Dragging = false
end

-- Gestion des événements de déplacement
TitleBar.InputBegan:Connect(StartDrag)
TitleBar.InputChanged:Connect(UpdateDrag)
TitleBar.InputEnded:Connect(EndDrag)

-- Bouton réduire/agrandir
ToggleButton.MouseButton1Click:Connect(ToggleMinimize)

-- Bouton fermer
