        AutoToggle.TextSize = newFontSize - 4
        
        for _, item in pairs(ScrollFrame:GetChildren()) do
            if item:IsA("Frame") and item.Name:match("ScriptItem") then
                for _, child in pairs(item:GetChildren()) do
                    if child:IsA("TextButton") and child.Name == "ExecuteButton" then
                        local btnW, btnH = GetAdaptiveButtonSize()
                        child.Size = UDim2.new(0, btnW, 0, btnH)
                        child.Position = UDim2.new(0.75, 0, 0.5, -btnH/2)
                        child.TextSize = GetAdaptiveFontSize() - 4
                    elseif child:IsA("TextLabel") then
                        if child.Name == "ScriptName" then
                            child.TextSize = GetAdaptiveFontSize() - 1
                        elseif child.Name == "AutoIndicator" then
                            child.TextSize = GetAdaptiveFontSize() - 5
                        elseif child.Name == "PlaceInfo" then
                            child.TextSize = GetAdaptiveFontSize() - 6
                        end
                    end
                end
            end
        end
    end
end)

