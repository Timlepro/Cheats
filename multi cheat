-- Attendre le chargement complet puis exécuter les scripts auto
local function WaitForLoad()
    local success = false
    local attempts = 0
    while not success and attempts < 30 do
        success = pcall(function()
            return LocalPlayer and LocalPlayer.PlayerGui and LocalPlayer.PlayerGui:FindFirstChild("ScriptExecutorGUI")
        end)
        if not success then
            task.wait(0.5)
            attempts = attempts + 1
        end
    end
    ExecuteAutoScripts()
end

task.spawn(WaitForLoad)

