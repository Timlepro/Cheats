    TweenService:Create(FloatButton, TweenInfo.new(0.3, Enum.EasingStyle.Back), { Size = UDim2.new(0,50,0,50) }):Play()
end

local function ShowWindow()
    MainFrame.Visible = true
    FloatButton.Visible = false
    -- bring to front animation
    TweenService:Create(MainFrame, TweenInfo.new(0.18, Enum.EasingStyle.Quad), { BackgroundTransparency = 0.95 }):Play()
