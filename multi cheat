-- TAILLE ADAPTATIVE EN POURCENTAGE
local function GetAdaptiveSize()
    local screenSize = workspace.CurrentCamera.ViewportSize
    local width = math.min(0.85, screenSize.X * 0.9 / screenSize.X)
    local height = math.min(0.8, screenSize.Y * 0.85 / screenSize.Y)
    
    if IsMobile or IsSmallScreen then
        width = math.min(0.92, screenSize.X * 0.92 / screenSize.X)
        height = math.min(0.85, screenSize.Y * 0.8 / screenSize.Y)
    end
    
    return width, height
end

local function GetAdaptiveFontSize()
    local screenSize = workspace.CurrentCamera.ViewportSize
    if IsMobile or IsSmallScreen then
        return math.max(12, screenSize.X * 0.022)
    end
    return math.max(14, screenSize.X * 0.025)
end

local function GetAdaptiveButtonSize()
    local screenSize = workspace.CurrentCamera.ViewportSize
    if IsMobile or IsSmallScreen then
        return math.max(50, screenSize.X * 0.1), math.max(22, screenSize.X * 0.045)
    end
    return math.max(60, screenSize.X * 0.09), math.max(26, screenSize.X * 0.04)
end

