task.wait(3)
ExecuteAutoScripts()

RunService.RenderStepped:Connect(function()
    if game.PlaceId ~= CurrentPlaceId then
        CurrentPlaceId = game.PlaceId
        for i = 1, #Scripts do
            ExecutedScripts[i] = false
            local item = ScrollFrame:FindFirstChild("ScriptItem_" .. i)
            if item then
                local indicator = item:FindFirstChild("AutoIndicator")
                if indicator then
                    indicator.Text = "⏳ En attente"
                    indicator.TextColor3 = Color3.fromRGB(200, 200, 200)
                end
            end
        end
        ExecuteAutoScripts()
    end
end)

RunService.RenderStepped:Connect(function()
    local currentSize = workspace.CurrentCamera.ViewportSize
    local isNowSmall = currentSize.X < 600
    
    if isNowSmall ~= IsSmallScreen then
        IsSmallScreen = isNowSmall
        IsMobile = UserInputService.TouchEnabled
        
        if FloatButton.Visible then
            FloatButton.Position = UDim2.new(0.5, -25, 0.02, 0)
        end
        
        UpdateMainFrameSize()
        
        local newFontSize = GetAdaptiveFontSize()
        Title.TextSize = newFontSize
        
        for _, item in pairs(ScrollFrame:GetChildren()) do
            if item:IsA("Frame") and item.Name:match("ScriptItem") then
                for _, child in pairs(item:GetChildren()) do
                    if child:IsA("TextButton") then
                        if child.Name == "ExecuteButton" then
                            local btnW, btnH = GetAdaptiveButtonSize()
                            child.Size = UDim2.new(0, btnW, 0, btnH)
                            child.Position = UDim2.new(0.78, 0, 0.15, 0)
                            child.TextSize = GetAdaptiveFontSize() - 4
                        elseif child.Name == "ToggleButton" then
