        TweenService:Create(ExecuteButton, TweenInfo.new(0.1), { Size = UDim2.new(0, btnW-5, 0, btnH-3) }):Play()
        task.wait(0.1)
        TweenService:Create(ExecuteButton, TweenInfo.new(0.1), { Size = UDim2.new(0, btnW, 0, btnH) }):Play()
        local oldText = ExecuteButton.Text
        ExecuteButton.Text = "⏳..."
        ExecuteButton.TextColor3 = Color3.fromRGB(255,200,100)
        local ok = ExecuteScript(scriptData.Url)
        task.wait(0.3)
        if ok then
            ExecuteButton.Text = "✅ Fait!"
            ExecuteButton.TextColor3 = Color3.fromRGB(0,255,0)
            task.wait(0.5)
        end
        ExecuteButton.Text = oldText
        ExecuteButton.TextColor3 = Color3.fromRGB(180,255,200)
        if ScriptToggles[index] and ShouldAutoExecute(scriptData, index) then
            ExecutedScripts[index] = true
            AutoIndicator.Text = "✅ Exécuté"
            AutoIndicator.TextColor3 = Color3.fromRGB(0,255,0)
            SaveToggles()
        end
    end)

    return ItemFrame
end

