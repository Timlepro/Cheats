    AutoIndicator.Name = "AutoIndicator"
    AutoIndicator.Size = UDim2.new(0.18, 0, 0.3, 0)
    AutoIndicator.Position = UDim2.new(0.63, 0, 0.55, 0)
    AutoIndicator.BackgroundTransparency = 1
    AutoIndicator.Text = ExecutedScripts[index] and "✅ Exécuté" or "⏳ En attente"
    AutoIndicator.TextColor3 = ExecutedScripts[index] and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(200, 200, 200)
    AutoIndicator.TextSize = GetAdaptiveFontSize() - 4
    AutoIndicator.TextXAlignment = Enum.TextXAlignment.Center
    AutoIndicator.Font = Enum.Font.GothamMedium
    AutoIndicator.Parent = ItemFrame
    AutoIndicator.ZIndex = 3

    local ExecuteButton = Instance.new("TextButton")
    ExecuteButton.Name = "ExecuteButton"
    local btnW, btnH = GetAdaptiveButtonSize()
    ExecuteButton.Size = UDim2.new(0.15, 0, 0.4, 0)
    ExecuteButton.Position = UDim2.new(0.82, 0, 0.3, 0)
    ExecuteButton.BackgroundColor3 = Color3.fromRGB(40, 180, 80)
    ExecuteButton.BackgroundTransparency = 0.2
    ExecuteButton.BorderSizePixel = 0
    ExecuteButton.Text = "▶ Run"
    ExecuteButton.TextColor3 = Color3.fromRGB(180, 255, 200)
    ExecuteButton.TextSize = GetAdaptiveFontSize() - 3
    ExecuteButton.Font = Enum.Font.GothamBold
    ExecuteButton.Parent = ItemFrame
    ExecuteButton.ZIndex = 3
    ExecuteButton.AutoButtonColor = false

    local ButtonCorner = Instance.new("UICorner")
    ButtonCorner.CornerRadius = UDim.new(0, 5)
    ButtonCorner.Parent = ExecuteButton

    local function ToggleScript()
        ScriptToggles[index] = not ScriptToggles[index]
        
        if ScriptToggles[index] then
            ToggleButton.Text = "✅ ON"
            ToggleButton.BackgroundColor3 = Color3.fromRGB(40, 180, 80)
            ToggleButton.BorderColor3 = Color3.fromRGB(40, 180, 80)
            ToggleButton.TextColor3 = Color3.fromRGB(180, 255, 200)
            
            if ShouldAutoExecute(scriptData, index) and not ExecutedScripts[index] then
                local success = ExecuteScript(scriptData.Url, scriptData.Name)
                if success then
                    ExecutedScripts[index] = true
                    AutoIndicator.Text = "✅ Exécuté"
                    AutoIndicator.TextColor3 = Color3.fromRGB(0, 255, 0)
                end
            end
        else
            ToggleButton.Text = "❌ OFF"
            ToggleButton.BackgroundColor3 = Color3.fromRGB(180, 40, 40)
            ToggleButton.BorderColor3 = Color3.fromRGB(180, 40, 40)
            ToggleButton.TextColor3 = Color3.fromRGB(255, 180, 180)
            ExecutedScripts[index] = false
            AutoIndicator.Text = "⏳ En attente"
            AutoIndicator.TextColor3 = Color3.fromRGB(200, 200, 200)
        end
        
        SaveToggles()
    end

    ToggleButton.MouseButton1Click:Connect(ToggleScript)

    if not IsMobile then
        ToggleButton.MouseEnter:Connect(function()
            TweenService:Create(ToggleButton, TweenInfo.new(0.2), {
                BackgroundTransparency = 0.1
            }):Play()
        end)

        ToggleButton.MouseLeave:Connect(function()
            TweenService:Create(ToggleButton, TweenInfo.new(0.2), {
                BackgroundTransparency = 0.2
            }):Play()
        end)

        ExecuteButton.MouseEnter:Connect(function()
            TweenService:Create(ExecuteButton, TweenInfo.new(0.2), {
                BackgroundTransparency = 0.1,
                BackgroundColor3 = Color3.fromRGB(50, 220, 100)
            }):Play()
        end)

        ExecuteButton.MouseLeave:Connect(function()
            TweenService:Create(ExecuteButton, TweenInfo.new(0.2), {
                BackgroundTransparency = 0.2,
                BackgroundColor3 = Color3.fromRGB(40, 180, 80)
            }):Play()
        end)
    end

    ExecuteButton.MouseButton1Click:Connect(function()
        if ExecuteButton.Text == "⏳..." then
            return
        end
        
        TweenService:Create(ExecuteButton, TweenInfo.new(0.1), {
            Size = UDim2.new(0.13, 0, 0.35, 0)
        }):Play()
        task.wait(0.1)
        TweenService:Create(ExecuteButton, TweenInfo.new(0.1), {
            Size = UDim2.new(0.15, 0, 0.4, 0)
        }):Play()

        local oldText = ExecuteButton.Text
        ExecuteButton.Text = "⏳..."
        ExecuteButton.TextColor3 = Color3.fromRGB(255, 200, 100)
        
        local success = ExecuteScript(scriptData.Url, scriptData.Name)
        
        task.wait(0.3)
        if success then
            ExecuteButton.Text = "✅ Fait!"
            ExecuteButton.TextColor3 = Color3.fromRGB(0, 255, 0)
            task.wait(0.5)
        end
        ExecuteButton.Text = oldText
        ExecuteButton.TextColor3 = Color3.fromRGB(180, 255, 200)
        
        if ScriptToggles[index] and ShouldAutoExecute(scriptData, index) then
            ExecutedScripts[index] = true
            AutoIndicator.Text = "✅ Exécuté"
            AutoIndicator.TextColor3 = Color3.fromRGB(0, 255, 0)
            SaveToggles()
        end
    end)

    return ItemFrame
end

