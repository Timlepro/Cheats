local function GetAdaptiveSize()
    local screenSize = workspace.CurrentCamera.ViewportSize
    local width = math.min(420, screenSize.X * 0.9)
    local height = math.min(600, screenSize.Y * 0.85)
    if IsMobile or IsSmallScreen then
        width = math.min(370, screenSize.X * 0.92)
        height = math.min(550, screenSize.Y * 0.8)
    end
    return width, height
end

