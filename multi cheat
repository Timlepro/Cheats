local PreferencesFile = "ScriptExecutor_Prefs.txt"

-- Fonction pour sauvegarder les préférences
local function SavePreferences()
    local data = {
        AutoExecuteEnabled = AutoExecuteEnabled,
        MainFramePosition = {
            X = MainFrame.Position.X.Scale,
            XOffset = MainFrame.Position.X.Offset,
            Y = MainFrame.Position.Y.Scale,
            YOffset = MainFrame.Position.Y.Offset
        },
        FloatButtonPosition = {
            X = FloatButton.Position.X.Scale,
            XOffset = FloatButton.Position.X.Offset,
            Y = FloatButton.Position.Y.Scale,
            YOffset = FloatButton.Position.Y.Offset
        },
        ExecutedScripts = ExecutedScripts,
        ScriptsConfig = {}
    }
    
    -- Sauvegarder la config de chaque script
    for i, scriptData in ipairs(Scripts) do
        data.ScriptsConfig[i] = {
            AutoExecute = scriptData.AutoExecute,
            PlaceIds = scriptData.PlaceIds
        }
    end
    
    -- Convertir en JSON
    local jsonData = game:GetService("HttpService"):JSONEncode(data)
    
    -- Sauvegarder
    local success, err = pcall(function()
        writefile(PreferencesFile, jsonData)
    end)
    
    if success then
        print("✅ Préférences sauvegardées!")
    else
        warn("❌ Erreur de sauvegarde: " .. err)
    end
end

-- Fonction pour charger les préférences
local function LoadPreferences()
    -- Vérifier si le fichier existe
    local fileExists, _ = pcall(function()
        return isfile(PreferencesFile)
    end)
    
    if not fileExists then
        print("📝 Fichier de préférences inexistant, création avec valeurs par défaut...")
        SavePreferences()
        return
    end
    
    -- Lire le fichier
    local success, jsonData = pcall(function()
        return readfile(PreferencesFile)
    end)
    
    if not success then
        print("❌ Erreur de lecture du fichier, création d'un nouveau...")
        SavePreferences()
        return
    end
    
    -- Décoder le JSON
    local data = nil
    local decodeSuccess, decodedData = pcall(function()
        return game:GetService("HttpService"):JSONDecode(jsonData)
    end)
    
    if not decodeSuccess then
        print("❌ Erreur de décodage JSON, création d'un nouveau fichier...")
        SavePreferences()
        return
    end
    
    data = decodedData
    
    -- Appliquer les préférences
    if data.AutoExecuteEnabled ~= nil then
        AutoExecuteEnabled = data.AutoExecuteEnabled
    end
    
    if data.MainFramePosition then
        MainFrame.Position = UDim2.new(
            data.MainFramePosition.X or 0.5,
            data.MainFramePosition.XOffset or -200,
            data.MainFramePosition.Y or 0.5,
            data.MainFramePosition.YOffset or -250
        )
    end
    
    if data.FloatButtonPosition then
        FloatButton.Position = UDim2.new(
            data.FloatButtonPosition.X or 0.5,
            data.FloatButtonPosition.XOffset or -25,
            data.FloatButtonPosition.Y or 0.02,
            data.FloatButtonPosition.YOffset or 0
        )
    end
    
    if data.ExecutedScripts then
        ExecutedScripts = data.ExecutedScripts
    end
    
    -- Appliquer la config des scripts
    if data.ScriptsConfig then
        for i, config in pairs(data.ScriptsConfig) do
            if Scripts[i] then
                Scripts[i].AutoExecute = config.AutoExecute
                Scripts[i].PlaceIds = config.PlaceIds or {}
            end
        end
    end
    
    print("✅ Préférences chargées avec succès!")
    print("📌 Auto-Execute: " .. (AutoExecuteEnabled and "ON" or "OFF"))
end

