-- Fonction pour exécuter un script (identique au bouton Run)
local function ExecuteScript(url, scriptName)
    if not url or url == "" then
        return false
    end
    
    local success = false
    
    -- Si c'est un loadstring direct
    if string.sub(url, 1, 10) == "loadstring" then
        success = pcall(function()
            loadstring(url)()
        end)
        return success
    end
    
    -- Si c'est une URL (Luarmor ou autre)
    local httpSuccess, response = pcall(function()
        return game:HttpGet(url)
    end)
    
    if not httpSuccess then
        return false
    end
    
    -- Essayer d'exécuter le script chargé
    local func, err = loadstring(response)
    if func then
        success = pcall(function()
            func()
        end)
    else
        -- Si loadstring échoue, essayer d'exécuter directement
        success = pcall(function()
            loadstring(response)()
        end)
    end
    
    return success
end

local function ShouldAutoExecute(scriptData, index)
    if not ScriptToggles[index] then
        return false
    end
    
    if scriptData.requirePlaceId then
        if #scriptData.PlaceIds == 0 then
            return false
        end
        local match = false
        for _, placeId in ipairs(scriptData.PlaceIds) do
            if placeId == CurrentPlaceId then
                match = true
                break
            end
        end
        if not match then
            return false
        end
    end
    
    return true
end

local function ExecuteAutoScripts()
    for i = 1, #Scripts do
        if ShouldAutoExecute(Scripts[i], i) and not ExecutedScripts[i] then
            local success = ExecuteScript(Scripts[i].Url, Scripts[i].Name)
            if success then
                ExecutedScripts[i] = true
                local item = ScrollFrame:FindFirstChild("ScriptItem_" .. i)
                if item then
                    local indicator = item:FindFirstChild("AutoIndicator")
                    if indicator then
                        indicator.Text = "✅ Exécuté"
                        indicator.TextColor3 = Color3.fromRGB(0, 255, 0)
                    end
                end
                SaveToggles()
            end
        end
    end
end

