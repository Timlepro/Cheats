-- Fonction pour exécuter un script
local function ExecuteScript(url, scriptName)
    if not url or url == "" then
        return false
    end
    
    local success = false
    
    if string.sub(url, 1, 10) == "loadstring" then
        success = pcall(function()
            loadstring(url)()
        end)
        return success
    end
    
    local httpSuccess, response = pcall(function()
        return game:HttpGet(url)
    end)
    
    if not httpSuccess then
        return false
    end
    
    local func, err = loadstring(response)
    if not func then
        return false
    end
    
    success = pcall(function()
        func()
    end)
    
    return success
end

-- Fonction pour vérifier si un script doit s'exécuter automatiquement
local function ShouldAutoExecute(scriptData)
    if not AutoExecuteEnabled then
        return false
    end
    
    if not scriptData.AutoExecute then
        return false
    end
    
    if #scriptData.PlaceIds == 0 then
        return false
    end
    
    for _, placeId in ipairs(scriptData.PlaceIds) do
        if placeId == CurrentPlaceId then
            return true
        end
    end
    
    return false
end

-- Fonction pour exécuter les scripts auto
local function ExecuteAutoScripts()
    for i, scriptData in ipairs(Scripts) do
        if ShouldAutoExecute(scriptData) and not ExecutedScripts[i] then
            local success = ExecuteScript(scriptData.Url, scriptData.Name)
            if success then
                ExecutedScripts[i] = true
                local item = ScrollFrame:FindFirstChild("ScriptItem_" .. i)
                if item then
                    local indicator = item:FindFirstChild("AutoIndicator")
                    if indicator then
                        indicator.Text = "✅ Auto Executed"
                        indicator.TextColor3 = Color3.fromRGB(0, 255, 0)
                    end
                end
                SavePreferences() -- Sauvegarder après une exécution auto
            end
        end
    end
end

