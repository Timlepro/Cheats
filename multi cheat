-- Fonction de déplacement
local function StartDrag(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        Dragging = true
        DragStart = input.Position
        StartPos = MainFrame.Position
    end
end

local function UpdateDrag(input)
    if Dragging then
        local delta = input.Position - DragStart
        MainFrame.Position = UDim2.new(
            StartPos.X.Scale,
            StartPos.X.Offset + delta.X,
            StartPos.Y.Scale,
            StartPos.Y.Offset + delta.Y
        )
    end
end

local function EndDrag()
    Dragging = false
end

-- Gestion des événements de déplacement
TitleBar.InputBegan:Connect(StartDrag)
TitleBar.InputChanged:Connect(UpdateDrag)
TitleBar.InputEnded:Connect(EndDrag)

-- Bouton fermer
CloseButton.MouseButton1Click:Connect(function()
    MainFrame.Visible = false
end)

-- Bouton hide/show
local IsHidden = false
HideButton.MouseButton1Click:Connect(function()
    IsHidden = not IsHidden
    MainFrame.Visible = not IsHidden
    if IsHidden then
        HideButton.ImageColor3 = Color3.fromRGB(50, 200, 50)
    else
        HideButton.ImageColor3 = Color3.fromRGB(200, 200, 50)
    end
end)

-- Rendre la GUI visible au démarrage
MainFrame.Visible = true

-- Raccourci clavier pour afficher/masquer (Ctrl + H)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.H and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
        IsHidden = not IsHidden
        MainFrame.Visible = not IsHidden
        if IsHidden then
            HideButton.ImageColor3 = Color3.fromRGB(50, 200, 50)
        else
            HideButton.ImageColor3 = Color3.fromRGB(200, 200, 50)
        end
    end
end)

