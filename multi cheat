local function SaveToggles()
    local data = {
        Toggles = {},
        ExecutedScripts = {},
        FloatPosition = {}
    }
    
    for i = 1, #Scripts do
        data.Toggles[i] = ScriptToggles[i] or false
    end
    
    for i = 1, #Scripts do
        data.ExecutedScripts[i] = ExecutedScripts[i] or false
    end
    
    if FloatButton then
        data.FloatPosition = {
            X = FloatButton.Position.X.Scale or 0.5,
            XOffset = FloatButton.Position.X.Offset or -25,
            Y = FloatButton.Position.Y.Scale or 0.02,
            YOffset = FloatButton.Position.Y.Offset or 0
        }
    else
        data.FloatPosition = {
            X = 0.5,
            XOffset = -25,
            Y = 0.02,
            YOffset = 0
        }
    end
    
    local jsonData = HttpService:JSONEncode(data)
    
    pcall(function()
        writefile(configFile, jsonData)
    end)
end

local function LoadToggles()
    if not isfile(configFile) then
        SaveToggles()
        return
    end

    local jsonData = nil
    local success, data = pcall(function()
        return readfile(configFile)
    end)
    
    if not success then
        SaveToggles()
        return
    end
    
    jsonData = data
    
    local decodedData = nil
    local decodeSuccess, result = pcall(function()
        return HttpService:JSONDecode(jsonData)
    end)
    
    if not decodeSuccess then
        SaveToggles()
        return
    end
    
    decodedData = result
    
    if decodedData.Toggles then
        for i = 1, #Scripts do
            if decodedData.Toggles[i] ~= nil then
                ScriptToggles[i] = decodedData.Toggles[i]
            end
        end
    end
    
    if decodedData.ExecutedScripts then
        for i = 1, #Scripts do
            if decodedData.ExecutedScripts[i] ~= nil then
                ExecutedScripts[i] = decodedData.ExecutedScripts[i]
            end
        end
    end
    
    if decodedData.FloatPosition and FloatButton then
        FloatButton.Position = UDim2.new(
            decodedData.FloatPosition.X or 0.5,
            decodedData.FloatPosition.XOffset or -25,
            decodedData.FloatPosition.Y or 0.02,
            decodedData.FloatPosition.YOffset or 0
        )
    end
end

