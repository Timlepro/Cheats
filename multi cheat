-- Float drag logic
local FloatDragging, FloatDragStart, FloatStartPos, FloatIsClick, FloatClickTime = false, nil, nil, false, 0
FloatButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        FloatIsClick = true
        FloatClickTime = tick()
        FloatDragging = false
        FloatDragStart = input.Position
        FloatStartPos = FloatButton.Position
    end
end)
FloatButton.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        if FloatIsClick and FloatDragStart then
            local delta = input.Position - FloatDragStart
            if math.abs(delta.X) > 5 or math.abs(delta.Y) > 5 then
                FloatDragging = true
                FloatIsClick = false
            end
        end
        if FloatDragging and FloatStartPos and FloatDragStart then
            local delta = input.Position - FloatDragStart
            FloatButton.Position = UDim2.new(FloatStartPos.X.Scale, FloatStartPos.X.Offset + delta.X, FloatStartPos.Y.Scale, FloatStartPos.Y.Offset + delta.Y)
        end
    end
end)
FloatButton.InputEnded:Connect(function()
    if FloatDragging then
        FloatDragging = false
        SaveToggles()
    end
    if FloatIsClick and (tick() - FloatClickTime) < 0.3 then
        -- ouverture via click
        MainFrame.Visible = true
        FloatButton.Visible = false
    end
    FloatIsClick = false
    FloatDragging = false
end)
FloatButton.MouseEnter:Connect(function()
    TweenService:Create(FloatButton, TweenInfo.new(0.2), { Size = UDim2.new(0,55,0,55), BackgroundTransparency = 0.05 }):Play()
