            ExecutedScripts[index] = true
            AutoIndicator.Text = "✅ Exécuté"
            AutoIndicator.TextColor3 = Color3.fromRGB(0, 255, 0)
            SaveToggles()
        end
    end)

    return ItemFrame
end

for i = 1, #Scripts do
    CreateScriptItem(Scripts[i], i)
end

local function UpdateCanvasSize()
    ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, (#Scripts * 83) + 10)
end
UpdateCanvasSize()

local function MinimizeWindow()
    SaveToggles()
    MainFrame.Visible = false
    FloatButton.Visible = true
    
    FloatButton.Size = UDim2.new(0, 35, 0, 35)
    TweenService:Create(FloatButton, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
        Size = UDim2.new(0, 50, 0, 50)
    }):Play()
end

local function ShowWindow()
    MainFrame.Visible = true
    FloatButton.Visible = false
end

local function CloseWindow()
    SaveToggles()
    MainFrame.Visible = false
    FloatButton.Visible = false
end

MinimizeButton.MouseButton1Click:Connect(MinimizeWindow)
FloatButton.MouseButton1Click:Connect(ShowWindow)
CloseButton.MouseButton1Click:Connect(CloseWindow)

LoadToggles()

for i = 1, #Scripts do
    local item = ScrollFrame:FindFirstChild("ScriptItem_" .. i)
    if item then
        local toggle = item:FindFirstChild("ToggleButton")
        local indicator = item:FindFirstChild("AutoIndicator")
        if toggle then
            if ScriptToggles[i] then
                toggle.Text = "✅ ON"
                toggle.BackgroundColor3 = Color3.fromRGB(40, 180, 80)
                toggle.BorderColor3 = Color3.fromRGB(40, 180, 80)
                toggle.TextColor3 = Color3.fromRGB(180, 255, 200)
            else
                toggle.Text = "❌ OFF"
                toggle.BackgroundColor3 = Color3.fromRGB(180, 40, 40)
                toggle.BorderColor3 = Color3.fromRGB(180, 40, 40)
                toggle.TextColor3 = Color3.fromRGB(255, 180, 180)
            end
        end
        if indicator and ExecutedScripts[i] then
            indicator.Text = "✅ Exécuté"
            indicator.TextColor3 = Color3.fromRGB(0, 255, 0)
        end
    end
end

