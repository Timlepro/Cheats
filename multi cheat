-- ====== FONCTIONS DE SAUVEGARDE / CHARGEMENT ======
local function SaveToggles()
    local data = {
        Toggles = {},
        ExecutedScripts = {},
        FloatPosition = {},
        DragEnabled = DragEnabled
    }

    for i, v in pairs(ScriptToggles) do data.Toggles[i] = v end
    for i, v in pairs(ExecutedScripts) do data.ExecutedScripts[i] = v end

    -- FloatButton peut ne pas exister encore, on vérifie
    if FloatButton and typeof(FloatButton.Position) == "UDim2" then
        data.FloatPosition = {
            X = FloatButton.Position.X.Scale,
            XOffset = FloatButton.Position.X.Offset,
            Y = FloatButton.Position.Y.Scale,
            YOffset = FloatButton.Position.Y.Offset
        }
    else
        data.FloatPosition = { X = 0.5, XOffset = -25, Y = 0.02, YOffset = 0 }
    end

    local ok, encoded = pcall(function() return HttpService:JSONEncode(data) end)
    if not ok then
        warn("Erreur JSON encode: " .. tostring(encoded))
        return
    end

    local success, err = pcall(function() writefile(configFile, encoded) end)
    if success then
        -- print("Config sauvegardée")
    else
        warn("Erreur sauvegarde config: " .. tostring(err))
    end
end

local function LoadToggles()
    if not isfile(configFile) then
        SaveToggles()
        return
    end

    local ok, raw = pcall(function() return readfile(configFile) end)
    if not ok then
        warn("Erreur lecture config, création d'une nouvelle config")
        SaveToggles()
        return
    end

    local decodeOk, data = pcall(function() return HttpService:JSONDecode(raw) end)
    if not decodeOk or type(data) ~= "table" then
        warn("Erreur décodage config, réinitialisation")
        SaveToggles()
        return
    end

    if data.Toggles then
        for i, v in pairs(data.Toggles) do
            if ScriptToggles[i] ~= nil then ScriptToggles[i] = v end
        end
    end

    if data.ExecutedScripts then
        for i, v in pairs(data.ExecutedScripts) do ExecutedScripts[i] = v end
    end

    if data.FloatPosition and FloatButton then
        local fp = data.FloatPosition
        FloatButton.Position = UDim2.new(fp.X or 0.5, fp.XOffset or -25, fp.Y or 0.02, fp.YOffset or 0)
    end

    if data.DragEnabled ~= nil then
        DragEnabled = data.DragEnabled
        -- UI update will be done after UI creation
    end
end

