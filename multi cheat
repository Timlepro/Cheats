-- Fonction pour exécuter un script
local function ExecuteScript(url, scriptName)
    if not url or url == "" then
        return
    end
    
    if string.sub(url, 1, 10) == "loadstring" then
        pcall(function()
            loadstring(url)()
        end)
        return
    end
    
    local success, response = pcall(function()
        return game:HttpGet(url)
    end)
    
    if not success then
        return
    end
    
    local func, err = loadstring(response)
    if not func then
        return
    end
    
    pcall(function()
        func()
    end)
end

-- Fonction pour créer un élément de script
local function CreateScriptItem(scriptData, index)
    local ItemFrame = Instance.new("Frame")
    ItemFrame.Name = "ScriptItem_" .. index
    ItemFrame.Size = UDim2.new(1, -10, 0, 55)
    ItemFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    ItemFrame.BackgroundTransparency = 0.3
    ItemFrame.BorderSizePixel = 1
    ItemFrame.BorderColor3 = Color3.fromRGB(50, 50, 65)
    ItemFrame.Parent = ScrollFrame

    local ItemCorner = Instance.new("UICorner")
    ItemCorner.CornerRadius = UDim.new(0, 6)
    ItemCorner.Parent = ItemFrame

    local ScriptName = Instance.new("TextLabel")
    ScriptName.Name = "ScriptName"
    ScriptName.Size = UDim2.new(0.6, 0, 1, 0)
    ScriptName.Position = UDim2.new(0.05, 0, 0, 0)
    ScriptName.BackgroundTransparency = 1
    ScriptName.Text = scriptData.Name
    ScriptName.TextColor3 = Color3.fromRGB(200, 200, 220)
    ScriptName.TextSize = GetAdaptiveFontSize() - 2
    ScriptName.TextXAlignment = Enum.TextXAlignment.Left
    ScriptName.Font = Enum.Font.GothamMedium
    ScriptName.Parent = ItemFrame

    local ExecuteButton = Instance.new("TextButton")
    ExecuteButton.Name = "ExecuteButton"
    local btnW, btnH = GetAdaptiveButtonSize()
    ExecuteButton.Size = UDim2.new(0, btnW, 0, btnH)
    ExecuteButton.Position = UDim2.new(0.7, 0, 0.5, -btnH/2)
    ExecuteButton.BackgroundColor3 = Color3.fromRGB(40, 180, 80)
    ExecuteButton.BackgroundTransparency = 0.2
    ExecuteButton.BorderSizePixel = 0
    ExecuteButton.Text = "▶ Exécuter"
    ExecuteButton.TextColor3 = Color3.fromRGB(180, 255, 200)
    ExecuteButton.TextSize = GetAdaptiveFontSize() - 4
    ExecuteButton.Font = Enum.Font.GothamBold
    ExecuteButton.Parent = ItemFrame
    ExecuteButton.AutoButtonColor = false

    local ButtonCorner = Instance.new("UICorner")
    ButtonCorner.CornerRadius = UDim.new(0, 5)
    ButtonCorner.Parent = ExecuteButton

    if not IsMobile then
        ExecuteButton.MouseEnter:Connect(function()
            TweenService:Create(ExecuteButton, TweenInfo.new(0.2), {
                BackgroundTransparency = 0.1,
                BackgroundColor3 = Color3.fromRGB(50, 220, 100)
            }):Play()
        end)

        ExecuteButton.MouseLeave:Connect(function()
            TweenService:Create(ExecuteButton, TweenInfo.new(0.2), {
                BackgroundTransparency = 0.2,
                BackgroundColor3 = Color3.fromRGB(40, 180, 80)
            }):Play()
        end)
    end

    ExecuteButton.MouseButton1Click:Connect(function()
        if ExecuteButton.Text == "⏳..." then
            return
        end
        
        TweenService:Create(ExecuteButton, TweenInfo.new(0.1), {
            Size = UDim2.new(0, btnW-5, 0, btnH-3)
        }):Play()
        task.wait(0.1)
        TweenService:Create(ExecuteButton, TweenInfo.new(0.1), {
            Size = UDim2.new(0, btnW, 0, btnH)
        }):Play()

        local oldText = ExecuteButton.Text
        ExecuteButton.Text = "⏳..."
        ExecuteButton.TextColor3 = Color3.fromRGB(255, 200, 100)
        
        ExecuteScript(scriptData.Url, scriptData.Name)
        
        task.wait(0.3)
        ExecuteButton.Text = oldText
        ExecuteButton.TextColor3 = Color3.fromRGB(180, 255, 200)
    end)

    return ItemFrame
end

-- Création des éléments de script
