-- ====== EXECUTION DE SCRIPTS ======
local function ExecuteScript(url)
    if not url or url == "" then return false end
    if string.sub(url,1,10) == "loadstring" then
        local ok, err = pcall(function() loadstring(url)() end)
        return ok
    end
    local ok, response = pcall(function() return game:HttpGet(url) end)
    if not ok or not response then return false end
    local func, err = loadstring(response)
    if not func then return false end
    local success = pcall(func)
    return success
end

local function ShouldAutoExecute(scriptData, index)
    if not ScriptToggles[index] then return false end
    if scriptData.requirePlaceId then
        if #scriptData.PlaceIds == 0 then return false end
        local match = false
        for _, pid in ipairs(scriptData.PlaceIds) do
            if pid == CurrentPlaceId then match = true break end
        end
        if not match then return false end
    end
    return true
end

local function ExecuteAutoScripts()
    local anyExecuted = false
    for i, sd in ipairs(Scripts) do
        if ShouldAutoExecute(sd, i) and not ExecutedScripts[i] then
            local ok = ExecuteScript(sd.Url)
            if ok then
                ExecutedScripts[i] = true
                anyExecuted = true
                local item = ScrollFrame:FindFirstChild("ScriptItem_"..i)
                if item then
                    local ind = item:FindFirstChild("AutoIndicator")
                    if ind then ind.Text = "✅ Exécuté"; ind.TextColor3 = Color3.fromRGB(0,255,0) end
                end
            end
        end
    end
    if anyExecuted then SaveToggles() end
end

