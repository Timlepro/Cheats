    MainFrame.Visible = false
end)

-- Rendre la GUI visible au démarrage
MainFrame.Visible = true

-- Raccourci clavier pour afficher/masquer (Ctrl + H) et réduire (Ctrl + M)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.H and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
        MainFrame.Visible = not MainFrame.Visible
    end
    
    if input.KeyCode == Enum.KeyCode.M and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
        ToggleMinimize()
    end
end)

-- Adaptation au redimensionnement de l'écran
RunService.RenderStepped:Connect(function()
    local currentSize = workspace.CurrentCamera.ViewportSize
    local isNowSmall = currentSize.X < 600
    
    if isNowSmall ~= IsSmallScreen then
        IsSmallScreen = isNowSmall
        IsMobile = UserInputService.TouchEnabled
        
        -- Mettre à jour les dimensions
        UpdateMainFrameSize()
        
        -- Mettre à jour les tailles de police
        local newFontSize = GetAdaptiveFontSize()
        Title.TextSize = newFontSize
        
        -- Mettre à jour les boutons
        for _, item in pairs(ScrollFrame:GetChildren()) do
            if item:IsA("Frame") and item.Name:match("ScriptItem") then
                for _, child in pairs(item:GetChildren()) do
                    if child:IsA("TextButton") and child.Name == "ExecuteButton" then
                        local btnW, btnH = GetAdaptiveButtonSize()
                        child.Size = UDim2.new(0, btnW, 0, btnH)
                        child.Position = UDim2.new(0.7, 0, 0.5, -btnH/2)
                        child.TextSize = GetAdaptiveFontSize() - 4
                    elseif child:IsA("TextLabel") and child.Name == "ScriptName" then
                        child.TextSize = GetAdaptiveFontSize() - 2
                    end
                end
            end
        end
    end
end)

-- Raccourci pour fermer avec Échap
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.Escape and MainFrame.Visible then
        MainFrame.Visible = false
    end
end)

