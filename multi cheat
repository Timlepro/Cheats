-- Dimensions adaptatives
local function GetAdaptiveSize()
    local screenSize = workspace.CurrentCamera.ViewportSize
    local width = math.min(420, screenSize.X * 0.9)
    local height = math.min(550, screenSize.Y * 0.85)
    
    if IsMobile or IsSmallScreen then
        width = math.min(370, screenSize.X * 0.92)
        height = math.min(500, screenSize.Y * 0.8)
    end
    
    return width, height
end

local function GetAdaptiveFontSize()
    if IsMobile or IsSmallScreen then
        return 13
    end
    return 17
end

local function GetAdaptiveButtonSize()
    if IsMobile or IsSmallScreen then
        return 65, 28
    end
    return 75, 32
end

